<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Confirmar pelo WhatsApp</title>

  <style>
    body{
      margin:0;
      font-family: Arial, sans-serif;
      background:#0b0b0b;
      color:#fff;
      min-height:100vh;
      display:flex;
      align-items:center;
      justify-content:center;
      padding:18px;
    }
    .box{
      width:720px;
      max-width:100%;
      background:#111;
      border:1px solid #222;
      border-radius:18px;
      padding:18px;
      box-shadow:0 14px 40px rgba(0,0,0,.55);
    }
    h1{margin:0 0 8px; font-size:22px;}
    .muted{color:#cfcfcf; font-weight:700; line-height:1.4;}
    .card{
      margin-top:14px;
      background:#0f0f0f;
      border:1px solid #222;
      border-radius:14px;
      padding:12px;
    }
    textarea{
      width:100%;
      min-height:220px;
      resize:vertical;
      border-radius:12px;
      border:1px solid #2a2a2a;
      background:#0b0b0b;
      color:#fff;
      padding:12px;
      font-size:14px;
      line-height:1.5;
      font-family: Arial, sans-serif;
      box-sizing:border-box;
    }
    .btns{
      display:flex;
      gap:10px;
      margin-top:12px;
      flex-wrap:wrap;
    }
    button, a{
      display:inline-block;
      text-decoration:none;
      padding:12px 14px;
      border-radius:14px;
      border:1px solid #333;
      font-weight:900;
      cursor:pointer;
      flex:1;
      min-width:220px;
      text-align:center;
    }
    .primary{
      background:#25D366;
      color:#111;
      border:none;
    }
    .secondary{
      background:#151515;
      color:#fff;
      border:1px solid #2a2a2a;
    }
    .hint{
      margin-top:10px;
      color:#bdbdbd;
      font-size:12px;
      font-weight:800;
    }
    .pill{
      display:inline-block;
      margin-top:10px;
      padding:6px 10px;
      border-radius:999px;
      background:#1a1a1a;
      border:1px solid #2a2a2a;
      color:#ddd;
      font-size:12px;
      font-weight:900;
    }
  </style>
</head>

<body>
  <%
    // ✅ fallback seguro: se waText não vier do backend, monta aqui
    const _nome = (typeof nome !== "undefined" ? String(nome) : "").trim();
    const _barberName = (typeof barberName !== "undefined" ? String(barberName) : "").trim();
    const _data = (typeof data !== "undefined" ? String(data) : "").trim();
    const _horario = (typeof horario !== "undefined" ? String(horario) : "").trim();
    const _confirmUrl = (typeof confirmUrl !== "undefined" ? String(confirmUrl) : "").trim();

    const _waText =
      (typeof waText !== "undefined" && waText)
        ? String(waText)
        : (
          `Olá! Quero confirmar meu agendamento na Gold Barber:\n\n` +
          `👤 Cliente: ${_nome}\n` +
          `💇‍♂️ Barbeiro: ${_barberName}\n` +
          `📅 Data: ${_data}\n` +
          `🕒 Horário: ${_horario}\n\n` +
          `✅ Clique para confirmar: ${_confirmUrl}`
        );

    // ✅ garante waLink mesmo se não vier (mas se vier, usa o seu)
    const _waLink =
      (typeof waLink !== "undefined" && waLink)
        ? String(waLink)
        : (
          // se não tiver número, ainda forma um link válido
          `https://wa.me/?text=${encodeURIComponent(_waText)}`
        );
  %>

  <div class="box">
    <h1>📲 Confirmar pelo WhatsApp</h1>

    <div class="pill">
      WhatsApp da barbearia: <%= barbershopWppDisplay || "—" %>
    </div>

    <div class="card">
      <textarea id="msg" readonly><%- _waText %></textarea>

      <div class="btns">
        <a class="primary" id="openWpp" href="<%- _waLink %>">Abrir WhatsApp</a>
      </div>

      <div class="hint">
        Dica: É necessario clicar no botão "abrir WhatsApp" para confirmar o agendamento do horario.
      </div>
    </div>

    <div class="btns" style="margin-top:14px;">
    </div>
  </div>

  <script>
    // ✅ seu script estava quebrando porque não existe #copyBtn
    // Mantive a página igual e só evitei erro no console.
  </script>
</body>
</html>