<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <title>Painel Admin</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <style>
    body{font-family:Arial, sans-serif; margin:0; padding:0; background:#fafafa;}
    header{background:#111; color:#fff; padding:14px 16px; display:flex; align-items:center; justify-content:space-between;}
    main{max-width:1100px; margin:18px auto; padding:0 16px;}
    .grid{display:grid; grid-template-columns:1fr; gap:16px;}
    .card{background:#fff; border:1px solid #e6e6e6; border-radius:12px; padding:14px;}
    h2{margin:0 0 10px 0;}
    table{width:100%; border-collapse:collapse; font-size:14px;}
    th, td{border-bottom:1px solid #eee; padding:10px; text-align:left; vertical-align: middle;}
    .row{display:flex; gap:10px; flex-wrap:wrap; align-items:center;}
    .pill{padding:4px 10px; border-radius:999px; background:#eee; font-size:12px; font-weight:900;}
    .btn{padding:10px 12px; border-radius:10px; border:1px solid #ddd; cursor:pointer; background:#fff; font-weight:900;}
    .btnPrimary{background:#111; color:#fff; border-color:#111;}
    .btnWarn{background:#c9a227; color:#111; border:none;}
    .btnDanger{background:#b00020; color:#fff; border:none;}
    input, select{padding:9px; border-radius:10px; border:1px solid #ccc;}
    label{font-weight:700; display:block; margin-top:10px; margin-bottom:6px;}
    .cols{display:grid; grid-template-columns:1fr 1fr; gap:12px;}
    .full{grid-column:1/-1;}
    .muted{color:#666; font-size:12px; font-weight:700;}
    .bad{color:#b00020; font-weight:900;}
    @media (max-width:800px){ .cols{grid-template-columns:1fr;} }

    .tabs{
      max-width:1100px;
      margin:14px auto 0;
      padding:0 16px;
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      align-items:center;
    }
    .tabBtn{
      border:1px solid #ddd;
      background:#fff;
      color:#111;
      border-radius:999px;
      padding:10px 14px;
      cursor:pointer;
      font-weight:900;
    }
    .tabBtn.active{
      background:#111;
      color:#fff;
      border-color:#111;
    }
    .tabPanel{display:none;}
    .tabPanel.active{display:block;}

    /* Agenda */
    .agendaWrap{display:grid; grid-template-columns: 1fr; gap:12px;}
    .dayCard{border:1px solid #e6e6e6; border-radius:14px; overflow:hidden; background:#fff;}
    .dayHeader{
      padding:12px 14px;
      background:#111;
      color:#fff;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      flex-wrap:wrap;
    }
    .dayHeader strong{font-size:15px;}
    .countBadge{
      background:#c9a227;
      color:#111;
      font-weight:900;
      padding:6px 10px;
      border-radius:999px;
      font-size:12px;
    }
    .slotList{padding:10px 12px 6px; display:grid; grid-template-columns: 1fr; gap:10px;}
    .slotItem{
      border:1px solid #eee;
      border-radius:12px;
      padding:10px 12px;
      display:flex;
      justify-content:space-between;
      align-items:flex-start;
      gap:10px;
      flex-wrap:wrap;
      background:#fafafa;
    }
    .slotLeft{display:flex; gap:10px; align-items:center; flex-wrap:wrap;}
    .timePill{
      background:#111;
      color:#fff;
      font-weight:900;
      padding:6px 10px;
      border-radius:999px;
      font-size:12px;
      min-width:72px;
      text-align:center;
    }
    .info{display:flex; flex-direction:column; gap:4px; font-size:13px; font-weight:800; color:#111;}
    .info small{font-weight:800; color:#666;}
    .slotRight{display:flex; gap:8px; flex-wrap:wrap; align-items:center; justify-content:flex-end;}

    .tag{border:1px solid #ddd; background:#fff; color:#111; border-radius:999px; padding:6px 10px; font-size:12px; font-weight:900;}
    .tag.confirmado{border-color:#0a7a2f; box-shadow:0 0 0 2px rgba(10,122,47,.12);}
    .tag.reservado{border-color:#c9a227; box-shadow:0 0 0 2px rgba(201,162,39,.18);}
    .tag.mensalista{border-color:#111; box-shadow:0 0 0 2px rgba(0,0,0,.12);}

    /* Picker de Mês (mais fácil de visualizar) */
    .monthPickerBox{display:flex; gap:8px; align-items:center; flex-wrap:nowrap;}
    .monthPickerBox .muted{color:#d8d8d8;}
    .monthPickerBox select{
      background:#151515;
      color:#fff;
      border:1px solid #2a2a2a;
      border-radius:12px;
      padding:10px 12px;
      font-weight:900;
      min-width:150px;
    }
    .monthPickerBox select:focus{outline: none; box-shadow: 0 0 0 2px rgba(201, 162, 39, 0.25);}
    .monthPickerHint{
      margin-top:6px;
      font-size:12px;
      font-weight:800;
      color:#666;
    }

    /* Calendário */
    .overlay {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,.65);
      display: none;
      align-items: center;
      justify-content: center;
      padding: 18px;
      z-index: 999;
    }
    .overlay.show { display: flex; }

    .cal {
      width: 360px;
      max-width: 100%;
      background: #111;
      border: 1px solid #2a2a2a;
      border-radius: 18px;
      overflow: hidden;
      box-shadow: 0 14px 40px rgba(0,0,0,.55);
      color: #fff;
      font-family: Arial, sans-serif;
    }
    .cal-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 12px 12px;
      background: #0d0d0d;
      border-bottom: 1px solid #222;
    }
    .cal-title { font-weight: 900; color: #fff; font-size: 14px; }
    .cal-nav { display: flex; gap: 8px; }
    .cal-nav button {
      border: 1px solid #2a2a2a;
      background: #151515;
      color: #fff;
      border-radius: 10px;
      padding: 8px 10px;
      cursor: pointer;
      font-weight: 900;
    }
    .cal-body { padding: 12px; }
    .dow {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 6px;
      margin-bottom: 8px;
      font-size: 11px;
      color: #bdbdbd;
      text-align: center;
      font-weight: 800;
    }
    .days { display: grid; grid-template-columns: repeat(7, 1fr); gap: 6px; }
    .day {
      border: 1px solid #2a2a2a;
      background: #141414;
      color: #fff;
      border-radius: 12px;
      padding: 10px 0;
      text-align: center;
      cursor: pointer;
      font-weight: 900;
      user-select: none;
    }
    .day.muted { opacity: .35; cursor: default; }
    .day.disabled { opacity: .25; cursor: not-allowed; }
    .day.selected {
      border-color: #c9a227;
      box-shadow: 0 0 0 2px rgba(201, 162, 39, 0.25);
    }
    .cal-foot {
      display: flex;
      gap: 10px;
      padding: 12px;
      border-top: 1px solid #222;
      background: #0d0d0d;
    }
    .cal-foot button {
      flex: 1;
      border-radius: 12px;
      padding: 12px;
      cursor: pointer;
      font-weight: 900;
      border: 1px solid #2a2a2a;
      background: #151515;
      color: #fff;
    }
    .cal-foot button.primary {
      background: #c9a227;
      color: #111;
      border: none;
    }
  </style>
</head>
<body>
  <%
    function ymdToDmy(ymd) {
      if (!ymd || typeof ymd !== "string") return "";
      const m = ymd.match(/^(\d{4})-(\d{2})-(\d{2})$/);
      if (!m) return ymd;
      return `${m[3]}/${m[2]}/${m[1]}`;
    }

    function weekdayLabel(n){
      const map = ["Domingo","Segunda","Terça","Quarta","Quinta","Sexta","Sábado"];
      return map[Number(n)] ?? String(n);
    }

    // AGENDAMENTOS: inclui aprovado (confirmado), reservado e mensalistas
    const agendaBase = (agendamentos || []).filter(a => a.status === "aprovado" || a.status === "reservado");
    const agendaAll = agendaBase.concat(mensalistaConfirmados || []);

    const agendaByDate = {};
    agendaAll.forEach(a => {
      const key = a.data || "";
      if (!agendaByDate[key]) agendaByDate[key] = [];
      agendaByDate[key].push(a);
    });

    const agendaDates = Object.keys(agendaByDate).sort((a,b) => String(a).localeCompare(String(b)));
    agendaDates.forEach(d => agendaByDate[d].sort((x,y) => String(x.horario).localeCompare(String(y.horario))));

    const expMin = (typeof reservaExpiraMinutos !== "undefined" && reservaExpiraMinutos !== null)
      ? Number(reservaExpiraMinutos)
      : 30;
  %>

  <header>
    <div>
      <strong>Painel Admin</strong>
      <span class="pill" style="margin-left:10px;">logado: <%= adminUser?.username %></span>
    </div>
    <form method="POST" action="/admin/logout">
      <button class="btn btnPrimary" type="submit">Sair</button>
    </form>
  </header>

  <div class="tabs">
    <button class="tabBtn active" id="tabBtnBarbeiros" type="button">Configuração</button>
    <button class="tabBtn" id="tabBtnConfig" type="button">Config por barbeiros</button>
    <button class="tabBtn" id="tabBtnMensalistas" type="button">Plano mensalista</button>
    <button class="tabBtn" id="tabBtnManual" type="button">Agendar manualmente</button>
    <button class="tabBtn" id="tabBtnAgendamentos" type="button">Agendamentos</button>
  </div>

  <main>
    <!-- TAB: CONFIGURAÇÃO -->
    <div class="tabPanel active" id="tabBarbeiros">
      <div class="grid">

        <div class="card">
          <h2>Configuração</h2>
          <div class="muted">
            O tempo abaixo controla em quantos minutos um agendamento <strong>reservado</strong> expira
            (se o cliente não confirmar no WhatsApp). Depois disso, ele é removido do banco.
          </div>

          <div class="row" style="margin-top:12px; align-items:center;">
            <label style="margin:0; display:flex; gap:10px; align-items:center; font-weight:900;">
              <input type="checkbox" id="agAutoRefreshToggle" />
              Atualização automática da aba Agendamentos (30s)
            </label>
            <span class="muted">Recarrega sozinho e mantém seus filtros (sem F5).</span>
          </div>

          <form method="POST" action="/admin/config/reserva" style="margin-top:12px;">
            <div class="cols">
              <div>
                <label>Tempo para expirar reserva (minutos)</label>
                <input type="number" name="reservaExpiraMinutos" min="1" max="720" value="<%= expMin %>" required />
                <div class="muted">Padrão: 30. Máximo: 720 (12h).</div>
              </div>
              <div style="display:flex; align-items:flex-end;">
                <button class="btn btnPrimary" type="submit" style="width:100%;">Salvar</button>
              </div>
            </div>
          </form>
        </div>

        <div class="card">
          <h2>Criar novo barbeiro</h2>
          <form method="POST" action="/admin/barbeiros/create" style="margin-top:10px;">
            <div class="cols">
              <div class="full">
                <label>Nome do barbeiro</label>
                <input name="name" placeholder="Ex: João" required />
              </div>
              <div class="full">
                <button class="btn btnPrimary" type="submit">Criar barbeiro</button>
              </div>
            </div>
          </form>
        </div>

        <div class="card">
          <h2>Barbeiros</h2>
          <div class="muted">⚠️ Excluir barbeiro apaga também os agendamentos e configs dele.</div>
          <table>
            <thead>
              <tr>
                <th style="width:60px;">ID</th>
                <th>Nome</th>
                <th style="width:110px;">Status</th>
                <th style="width:260px;">Ações</th>
              </tr>
            </thead>
            <tbody>
              <% barbers.forEach(b => { %>
                <tr>
                  <td><%= b.id %></td>
                  <td>
                    <form method="POST" action="/admin/barbeiros/<%= b.id %>/nome" style="display:flex; gap:8px; align-items:center; flex-wrap:wrap;">
                      <input name="name" value="<%= b.name %>" style="width:240px;" />
                      <button class="btn" type="submit">Salvar</button>
                    </form>
                  </td>
                  <td><%= b.is_active ? "Ativo" : "Inativo" %></td>
                  <td style="display:flex; gap:8px; flex-wrap:wrap;">
                    <form method="POST" action="/admin/barbeiros/<%= b.id %>/toggle" style="display:inline;">
                      <button class="btn" type="submit"><%= b.is_active ? "Desativar" : "Ativar" %></button>
                    </form>

                    <form method="POST" action="/admin/barbeiros/<%= b.id %>/delete"
                          onsubmit="return confirm('Excluir o barbeiro <%= b.name %>?\\n\\nIsso vai apagar TODOS os agendamentos e configs dele.');">
                      <button class="btn btnDanger" type="submit">Excluir</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

      </div>
    </div>

    <!-- TAB: CONFIG POR BARBEIROS -->
    <div class="tabPanel" id="tabConfig">
      <div class="grid">
        <div class="card">
          <h2>Configuração por barbeiro</h2>

          <% barbers.forEach(b => {
              const cfg = barberConfigs[b.id];
              const dmyList = (cfg.daysOffDates || []).map(ymdToDmy).join(", ");
          %>
            <hr style="border:0; border-top:1px solid #eee; margin:18px 0;">
            <h3 style="margin:0 0 10px 0;"><%= b.name %> (ID <%= b.id %>)</h3>

            <form method="POST" action="/admin/barbeiro/<%= b.id %>/config">
              <div class="cols">
                <div>
                  <label>Início</label>
                  <input name="start" value="<%= cfg.start %>" placeholder="09:00" required />
                </div>
                <div>
                  <label>Fim</label>
                  <input name="end" value="<%= cfg.end %>" placeholder="18:00" required />
                </div>

                <div>
                  <label>Almoço (início)</label>
                  <input name="lunchStart" value="<%= cfg.lunchStart %>" placeholder="12:00" required />
                </div>
                <div>
                  <label>Almoço (fim)</label>
                  <input name="lunchEnd" value="<%= cfg.lunchEnd %>" placeholder="13:00" required />
                </div>

                <div class="full">
                  <label>Duração do slot (minutos)</label>
                  <input name="slotMinutes" type="number" value="<%= cfg.slotMinutes %>" min="10" max="240" required />
                </div>

                <div class="full">
                  <label>Dias de trabalho</label>
                  <div class="row">
                    <label><input type="checkbox" name="wd0" <%= cfg.workDays[0] ? "checked" : "" %> /> Dom</label>
                    <label><input type="checkbox" name="wd1" <%= cfg.workDays[1] ? "checked" : "" %> /> Seg</label>
                    <label><input type="checkbox" name="wd2" <%= cfg.workDays[2] ? "checked" : "" %> /> Ter</label>
                    <label><input type="checkbox" name="wd3" <%= cfg.workDays[3] ? "checked" : "" %> /> Qua</label>
                    <label><input type="checkbox" name="wd4" <%= cfg.workDays[4] ? "checked" : "" %> /> Qui</label>
                    <label><input type="checkbox" name="wd5" <%= cfg.workDays[5] ? "checked" : "" %> /> Sex</label>
                    <label><input type="checkbox" name="wd6" <%= cfg.workDays[6] ? "checked" : "" %> /> Sáb</label>
                  </div>
                </div>

                <div class="full">
                  <label>Folgas (DD/MM/AAAA, separadas por vírgula/espaco)</label>
                  <input name="daysOffDates" value="<%= dmyList %>" placeholder="10/02/2026, 11/02/2026" />
                </div>

                <div class="full">
                  <button class="btn btnPrimary" type="submit">Salvar config do <%= b.name %></button>
                </div>
              </div>
            </form>
          <% }) %>
        </div>
      </div>
    </div>

    <!-- TAB: PLANO MENSALISTA -->
    <div class="tabPanel" id="tabMensalistas">
      <!-- (mantido igual ao seu) -->
      <div class="grid">
        <div class="card">
          <h2>Plano mensalista</h2>
          <div class="muted">
            Cria um bloqueio fixo semanal (ex.: toda quarta 18:30). Esse horário fica indisponível no agendamento público.
          </div>

          <div id="menEditPill" class="pill" style="display:none; margin-top:10px; background:#fff5cf; border:1px solid #e6d18a;">
            Editando mensalista: <strong id="menEditName"></strong>
          </div>

          <form method="POST" action="/admin/mensalistas" id="mensalistaForm" style="margin-top:12px;">
            <input type="hidden" id="menPlanId" value="" />
            <input type="hidden" name="start" id="menStart" />
            <input type="hidden" name="end" id="menEnd" />

            <div class="cols">
              <div>
                <label>Barbeiro</label>
                <select name="barberId" id="menBarberId" required>
                  <option value="">Selecione</option>
                  <% barbers.forEach(b => { %>
                    <option value="<%= b.id %>"><%= b.name %></option>
                  <% }) %>
                </select>
              </div>

              <div>
                <label>Nome do mensalista</label>
                <input name="nome" id="menNome" placeholder="Ex: Gabriel" required />
              </div>

              <div>
                <label>Dia da semana</label>
                <select name="weekday" id="menWeekday" required>
                  <option value="">Selecione</option>
                  <option value="0">Domingo</option>
                  <option value="1">Segunda</option>
                  <option value="2">Terça</option>
                  <option value="3">Quarta</option>
                  <option value="4">Quinta</option>
                  <option value="5">Sexta</option>
                  <option value="6">Sábado</option>
                </select>
              </div>

              <div>
                <label>Horário</label>
                <select name="horario" id="menHorario" required disabled>
                  <option value="">Selecione barbeiro e dia da semana</option>
                </select>
                <div class="muted" id="menHorarioMsg"></div>
              </div>

              <div class="full" style="display:flex; gap:10px; flex-wrap:wrap;">
                <button class="btn btnPrimary" type="submit" id="menSubmitBtn">Salvar plano mensalista</button>
                <button class="btn" type="button" id="menCancelEdit" style="display:none;">Cancelar edição</button>
              </div>
            </div>
          </form>
        </div>

        <div class="card">
          <div class="row" style="justify-content:space-between; align-items:flex-end;">
            <div>
              <h2 style="margin:0 0 6px 0;">Mensalistas cadastrados</h2>
              <div class="muted">Filtre para encontrar mais rápido.</div>
            </div>

            <div class="row" style="align-items:flex-end;">
              <div>
                <span class="muted" style="font-weight:900;">Barbeiro</span><br/>
                <select id="menBarberFilter">
                  <option value="">Todos</option>
                  <% barbers.forEach(b => { %>
                    <option value="<%= b.id %>"><%= b.name %></option>
                  <% }) %>
                </select>
              </div>

              <div class="pill" style="background:#f1f1f1; align-self:center;">
                Total: <span id="menTotal">0</span>
              </div>
            </div>
          </div>

          <% if (!(mensalistas || []).length) { %>
            <div class="muted">Nenhum plano mensalista cadastrado ainda.</div>
          <% } else { %>
            <table>
              <thead>
                <tr>
                  <th>Barbeiro</th>
                  <th>Nome</th>
                  <th>Dia da Semana</th>
                  <th>Horário</th>
                  <th style="width:210px;">Ações</th>
                </tr>
              </thead>
              <tbody id="menListBody">
                <% mensalistas.forEach(m => { %>
                  <tr
                    class="menRow"
                    data-men-id="<%= m.id %>"
                    data-men-barber-id="<%= m.barber_id %>"
                    data-men-nome="<%- String(m.nome || '').replace(/\"/g, '&quot;') %>"
                    data-men-start="<%= m.start_ymd %>"
                    data-men-end="<%= m.end_ymd || '' %>"
                    data-men-weekday="<%= m.weekday %>"
                    data-men-horario="<%= m.horario %>"
                  >
                    <td><%= m.barber_name || m.barber_id %></td>
                    <td><%= m.nome %></td>
                    <td><%= weekdayLabel(m.weekday) %></td>
                    <td><%= m.horario %></td>
                    <td style="display:flex; gap:8px; flex-wrap:wrap;">
                      <button class="btn" type="button" onclick="startEditMensalista(this)">Editar</button>
                      <form method="POST" action="/admin/mensalistas/<%= m.id %>/delete" onsubmit="return confirm('Remover este plano mensalista?');">
                        <button class="btn" type="submit">Remover</button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          <% } %>
        </div>
      </div>
    </div>

    <!-- TAB: MANUAL -->
    <div class="tabPanel" id="tabManual">
      <!-- (mantido igual ao seu) -->
      <div class="grid">
        <div class="card">
          <h2>Agendar manualmente</h2>
          <div class="muted">✅ Todo agendamento manual é salvo automaticamente como <strong>aprovado</strong>.</div>

          <form method="POST" action="/admin/agendar" id="adminAgendarForm">
            <div class="cols">
              <div>
                <label>Barbeiro</label>
                <select name="barberId" id="admBarberId" required>
                  <option value="">Selecione</option>
                  <% barbers.forEach(b => { %>
                    <option value="<%= b.id %>"><%= b.name %></option>
                  <% }) %>
                </select>
              </div>

              <div>
                <label>Data (DD/MM/AAAA)</label>
                <input name="data" id="admData" placeholder="Clique para escolher" required readonly style="cursor:pointer; background:#f9f9f9;" />
              </div>

              <div>
                <label>Horário</label>
                <select name="horario" id="admHorario" required disabled>
                  <option value="">Selecione barbeiro e data</option>
                </select>
                <div id="admHorarioMsg" class="muted"></div>
              </div>

              <div class="full">
                <label>Nome do cliente</label>
                <input name="nome" id="admNome" placeholder="Nome do cliente" required />
              </div>

              <div class="full">
                <button class="btn btnPrimary" type="submit">Salvar agendamento</button>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>

    <!-- TAB: AGENDAMENTOS -->
    <div class="tabPanel" id="tabAgendamentos">
      <div class="grid">
        <div class="card">
          <div class="row" style="justify-content:space-between;">
            <div>
              <h2 style="margin:0;">Agendamentos</h2>
              <div class="muted">
                Filtre por barbeiro, período e tipo (reservado/confirmado/mensalista).
              </div>
            </div>

            <div class="row" style="align-items:flex-end;">
              <div>
                <span class="muted" style="font-weight:900;">Barbeiro</span><br/>
                <select id="agBarberFilter">
                  <option value="">Selecione</option>
                  <% barbers.forEach(b => { %>
                    <option value="<%= b.id %>"><%= b.name %></option>
                  <% }) %>
                </select>
              </div>

              <div>
                <span class="muted" style="font-weight:900;">Período</span><br/>
                <select id="agPeriodo">
                  <option value="hoje">Hoje</option>
                  <option value="semana">Semana (Seg–Sáb)</option>
                  <option value="mes">Mês (hoje → fim do mês)</option>
                  <option value="mes_inteiro">Mês inteiro (selecionar)</option>
                </select>
              </div>

              <!-- MÊS INTEIRO (melhor seleção) -->
              <div id="agMesWrap" style="display:none;">
                <span class="muted" style="font-weight:900;">Mês</span><br/>
                <div class="monthPickerBox">
                  <select id="agMesMonth" aria-label="Mês">
                    <option value="">Mês</option>
                    <option value="01">Janeiro</option>
                    <option value="02">Fevereiro</option>
                    <option value="03">Março</option>
                    <option value="04">Abril</option>
                    <option value="05">Maio</option>
                    <option value="06">Junho</option>
                    <option value="07">Julho</option>
                    <option value="08">Agosto</option>
                    <option value="09">Setembro</option>
                    <option value="10">Outubro</option>
                    <option value="11">Novembro</option>
                    <option value="12">Dezembro</option>
                  </select>

                  <select id="agMesYear" aria-label="Ano">
                    <option value="">Ano</option>
                  </select>
                </div>
</div>

              <div>
                <span class="muted" style="font-weight:900;">Tipo</span><br/>
                <select id="agTipo">
                  <option value="todos">Todos</option>
                  <option value="reservado">Reservado</option>
                  <option value="confirmado">Confirmado</option>
                  <option value="mensalista">Mensalista</option>
                </select>
              </div>

              <div class="pill" style="background:#f1f1f1; align-self:center;">
                Total: <span id="agTotal">0</span>
              </div>

              <button class="btn" type="button" id="agRefreshBtn" title="Recarregar agendamentos (sem precisar dar F5)">
                Atualizar
              </button>

              <div class="muted" style="align-self:center;">
                Última atualização: <span id="agLastUpdate">—</span>
              </div>

              <div class="muted" style="align-self:center;">
                Próxima em: <span id="agNextRefresh">—</span>
              </div>
            </div>
          </div>

          <div id="agHint" class="bad" style="display:none; margin-top:10px;">
            Selecione um barbeiro para listar os agendamentos.
          </div>

          <div class="muted" id="agPeriodoLabel" style="margin-top:10px;">—</div>

          <div class="row" style="margin-top:10px; gap:8px;">
            <span class="tag confirmado">confirmado</span>
            <span class="tag reservado">reservado</span>
            <span class="tag mensalista">mensalista</span>
          </div>
        </div>

        <div class="card">
          <% if (!agendaAll.length) { %>
            <div class="muted">Nenhum agendamento ainda.</div>
          <% } else { %>
            <div class="agendaWrap" id="agAgenda">
              <% agendaDates.forEach(dateKey => {
                   const items = agendaByDate[dateKey] || [];
              %>
                <div class="dayCard agDayCard" data-date="<%= dateKey %>">
                  <div class="dayHeader">
                    <strong><%= ymdToDmy(dateKey) %></strong>
                    <span class="countBadge"><span class="agDayCount"><%= items.length %></span> horário(s)</span>
                  </div>

                  <div class="slotList">
                    <% items.forEach(a => { %>
                      <%
                        const isMensalista = !!a.is_mensalista;
                        const st = isMensalista ? "mensalista" : (a.status || "");
                        const isConfirmado = (!isMensalista && st === "aprovado");
                        const isReservado = (!isMensalista && st === "reservado");
                        const tagClass = isMensalista ? "mensalista" : (isConfirmado ? "confirmado" : "reservado");
                        const tagText = isMensalista ? "mensalista" : (isConfirmado ? "confirmado" : "reservado");
                      %>

                      <div
                        class="slotItem agSlot"
                        data-id="<%= a.id %>"
                        data-barber-id="<%= a.barber_id %>"
                        data-status="<%= st %>"
                        data-is-mensalista="<%= isMensalista ? '1' : '0' %>"
                      >
                        <div class="slotLeft">
                          <span class="timePill"><%= a.horario %></span>
                          <div class="info">
                            <div><%= a.nome %></div>
                            <small>Barbeiro: <%= a.barber_name || "" %></small>
                          </div>
                        </div>

                        <div class="slotRight">
                          <span class="tag <%= tagClass %>"><%= tagText %></span>

                          <% if (isReservado) { %>
                            <button class="btn btnWarn" type="button" onclick="confirmarManual(<%= a.id %>)">
                              Confirmar manualmente
                            </button>
                          <% } %>

                          <% if (!isMensalista) { %>
                            <button class="btn" type="button" onclick="cancelarAg(<%= a.id %>)">Cancelar</button>
                          <% } %>
                        </div>
                      </div>
                    <% }) %>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </main>

  <!-- Calendário -->
  <div id="admOverlay" class="overlay" aria-hidden="true">
    <div class="cal" role="dialog" aria-modal="true" aria-label="Selecionar data">
      <div class="cal-head">
        <div class="cal-title" id="admCalTitle">Mês</div>
        <div class="cal-nav">
          <button type="button" id="admPrevMonth">◀</button>
          <button type="button" id="admNextMonth">▶</button>
        </div>
      </div>
      <div class="cal-body">
        <div class="dow">
          <div>DOM</div><div>SEG</div><div>TER</div><div>QUA</div><div>QUI</div><div>SEX</div><div>SÁB</div>
        </div>
        <div id="admDays" class="days"></div>
      </div>
      <div class="cal-foot">
        <button type="button" id="admCancelCal">Cancelar</button>
        <button type="button" class="primary" id="admOkCal">Confirmar</button>
      </div>
    </div>
  </div>

  <script>
    function pad2(n){ return String(n).padStart(2, "0"); }
    function fmtYMD(d){ return `${d.getFullYear()}-${pad2(d.getMonth()+1)}-${pad2(d.getDate())}`; }

    // ✅ Label em DD-MM-AAAA (apenas visual; o filtro continua em YYYY-MM-DD internamente)
    function fmtDMY(d){ return `${pad2(d.getDate())}-${pad2(d.getMonth()+1)}-${d.getFullYear()}`; }

    function addDays(d, days){ const x = new Date(d.getTime()); x.setDate(x.getDate()+days); return x; }
    function parseYMD(ymd){
      if(!ymd) return null;
      const m = String(ymd).match(/^(\d{4})-(\d{2})-(\d{2})$/);
      if(!m) return null;
      return new Date(Number(m[1]), Number(m[2])-1, Number(m[3]));
    }
    function dmyToYMD(dmy){
      if(!dmy) return null;
      const m = String(dmy).match(/^(\d{2})[\/\-](\d{2})[\/\-](\d{4})$/);
      if(!m) return null;
      return `${m[3]}-${m[2]}-${m[1]}`;
    }
    function minutesNow(){
      const n = new Date();
      return n.getHours() * 60 + n.getMinutes();
    }
    function timeToMinutes(hhmm){
      const m = String(hhmm || "").match(/^(\d{2}):(\d{2})$/);
      if(!m) return null;
      return Number(m[1]) * 60 + Number(m[2]);
    }

    const tabs = [
      { btn: "tabBtnBarbeiros", panel:"tabBarbeiros" },
      { btn: "tabBtnConfig", panel:"tabConfig" },
      { btn: "tabBtnMensalistas", panel:"tabMensalistas" },
      { btn: "tabBtnManual", panel:"tabManual" },
      { btn: "tabBtnAgendamentos", panel:"tabAgendamentos" },
    ];

    function activateTab(btnId){
      tabs.forEach(t=>{
        const b = document.getElementById(t.btn);
        const p = document.getElementById(t.panel);
        const active = (t.btn === btnId);
        b.classList.toggle("active", active);
        p.classList.toggle("active", active);
      });
      if(btnId === "tabBtnAgendamentos") applyAgendamentos();
      // liga/desliga auto-refresh dependendo da aba ativa
      stopAutoRefresh();
      startAutoRefreshIfNeeded();
      if(btnId === "tabBtnMensalistas"){
        if(menStart && !menStart.value) menStart.value = todayYMDMen();
      }
    }
    tabs.forEach(t=>{
      document.getElementById(t.btn).addEventListener("click", ()=>activateTab(t.btn));
    });

    async function updateStatus(id, status){
      const r = await fetch("/admin/status", {
        method:"POST",
        headers:{ "Content-Type":"application/json" },
        body: JSON.stringify({ id, status })
      });
      const j = await r.json();
      if(!j.ok) throw new Error("fail");
    }

    window.confirmarManual = async function(id){
      if(!confirm("Confirmar manualmente este agendamento?")) return;
      try{
        await updateStatus(id, "aprovado");
        const el = document.querySelector(`.agSlot[data-id="${id}"]`);
        if(el) el.dataset.status = "aprovado";
        applyAgendamentos();
      }catch(e){ alert("Erro ao confirmar."); }
    };

    window.cancelarAg = async function(id){
      if(!confirm("Cancelar este agendamento?")) return;
      try{
        await updateStatus(id, "cancelado");
        const el = document.querySelector(`.agSlot[data-id="${id}"]`);
        if(el) el.dataset.status = "cancelado";
        applyAgendamentos();
      }catch(e){ alert("Erro ao cancelar."); }
    };

    // ===== AGENDAMENTOS FILTER (PROFISSIONAL) =====
    const agBarberFilter = document.getElementById("agBarberFilter");
    const agPeriodo = document.getElementById("agPeriodo");
    const agTipo = document.getElementById("agTipo");
    const agMesWrap = document.getElementById("agMesWrap");

    // Novo picker (mês/ano) - bem mais fácil
    const agMesMonth = document.getElementById("agMesMonth");
    const agMesYear = document.getElementById("agMesYear");

    const agPeriodoLabel = document.getElementById("agPeriodoLabel");
    const agHint = document.getElementById("agHint");
    const agTotal = document.getElementById("agTotal");

    function startOfWorkWeekMon(d){
      const day = d.getDay(); // 0=dom ... 6=sab
      const diffToMon = (day === 0) ? -6 : (1 - day);
      const mon = new Date(d.getFullYear(), d.getMonth(), d.getDate());
      mon.setDate(mon.getDate() + diffToMon);
      return mon;
    }

    function endOfWorkWeekSat(d){
      const mon = startOfWorkWeekMon(d);
      const sat = new Date(mon.getFullYear(), mon.getMonth(), mon.getDate());
      sat.setDate(sat.getDate() + 5); // seg + 5 = sab
      return sat;
    }

    function lastDayOfMonth(d){
      return new Date(d.getFullYear(), d.getMonth() + 1, 0);
    }

    function buildMonthYearOptions(){
      // deixa o select de ano mais "ditado": mostra uma faixa de anos sem precisar digitar
      const now = new Date();
      const currentYear = now.getFullYear();
      const startY = currentYear - 2;
      const endY = currentYear + 3;

      agMesYear.innerHTML = `<option value="">Ano</option>` + Array.from({length: (endY-startY+1)}, (_,i)=>{
        const y = startY + i;
        return `<option value="${y}">${y}</option>`;
      }).join("");

      // defaults para facilitar: mês/ano atual
      agMesYear.value = String(currentYear);
      agMesMonth.value = pad2(now.getMonth()+1);
    }

    function rangeForPeriodo(){
      const now = new Date();
      const p = agPeriodo.value;

      if (p === "hoje"){
        const ymd = fmtYMD(now);
        return { start: ymd, end: ymd, label: `Hoje (${fmtDMY(now)})` };
      }

      if (p === "semana"){
        const mon = startOfWorkWeekMon(now);
        const sat = endOfWorkWeekSat(now);
        return {
          start: fmtYMD(mon),
          end: fmtYMD(sat),
          label: `Semana (Seg–Sáb): ${fmtDMY(mon)} → ${fmtDMY(sat)}`
        };
      }

      if (p === "mes"){
        const end = lastDayOfMonth(now);
        return {
          start: fmtYMD(now),
          end: fmtYMD(end),
          label: `Mês (hoje → fim): ${fmtDMY(now)} → ${fmtDMY(end)}`
        };
      }

      // mes_inteiro (mês + ano)
      const mm = agMesMonth.value; // "01".."12"
      const yy = agMesYear.value;  // "2026"
      if (!mm || !yy){
        return { start: "", end: "", label: "Selecione mês e ano." };
      }

      const yearNum = Number(yy);
      const monthNum = Number(mm); // 1-12
      const first = new Date(yearNum, monthNum - 1, 1);
      const last = new Date(yearNum, monthNum, 0);

      return {
        start: fmtYMD(first),
        end: fmtYMD(last),
        label: `Mês inteiro: ${fmtDMY(first)} → ${fmtDMY(last)}`
      };
    }

    function tipoMatches(slotEl){
      const isMensalista = slotEl.dataset.isMensalista === "1";
      const st = slotEl.dataset.status || "";

      const t = agTipo.value;
      if (t === "todos") return true;
      if (t === "mensalista") return isMensalista;
      if (t === "confirmado") return !isMensalista && st === "aprovado";
      if (t === "reservado") return !isMensalista && st === "reservado";
      return true;
    }

    function applyAgendamentos(){
      const bId = agBarberFilter.value;

      // barbeiro obrigatório (mantido)
      agHint.style.display = bId ? "none" : "";

      // mês inteiro: mostra picker mais fácil
      if (agPeriodo.value === "mes_inteiro"){
        agMesWrap.style.display = "";
      } else {
        agMesWrap.style.display = "none";
      }

      const { start, end, label } = rangeForPeriodo();
      if (agPeriodoLabel) agPeriodoLabel.textContent = label;

      let totalShown = 0;

      document.querySelectorAll(".agDayCard").forEach(card=>{
        const dateKey = card.dataset.date;

        let inRange = !!bId;
        if (inRange && start && dateKey < start) inRange = false;
        if (inRange && end && dateKey > end) inRange = false;

        let dayCount = 0;

        card.querySelectorAll(".agSlot").forEach(slot=>{
          const sb = slot.dataset.barberId;
          const isMen = slot.dataset.isMensalista === "1";
          const st = slot.dataset.status || "";

          if(st === "cancelado"){
            slot.style.display = "none";
            return;
          }

          let ok = true;

          if(!inRange) ok = false;
          if(ok && sb !== bId) ok = false;

          if (!tipoMatches(slot)) ok = false;

          slot.style.display = ok ? "" : "none";
          if(ok){ dayCount++; totalShown++; }

          const tag = slot.querySelector(".tag");
          const btnConfirm = slot.querySelector(".btnWarn");

          if(tag){
            if(isMen){
              tag.className = "tag mensalista";
              tag.textContent = "mensalista";
              if(btnConfirm) btnConfirm.style.display = "none";
            }else if(st === "aprovado"){
              tag.className = "tag confirmado";
              tag.textContent = "confirmado";
              if(btnConfirm) btnConfirm.style.display = "none";
            }else{
              tag.className = "tag reservado";
              tag.textContent = "reservado";
              if(btnConfirm) btnConfirm.style.display = "";
            }
          }
        });

        const badge = card.querySelector(".agDayCount");
        if(badge) badge.textContent = String(dayCount);
        card.style.display = (dayCount > 0) ? "" : "none";
      });

      agTotal.textContent = String(totalShown);

      // mantém as seleções persistidas + atualiza horário
      saveAgFilters();
      updateAgLastUpdate();
    }

    // listeners
    ["change","input"].forEach(evt=>{
      agBarberFilter.addEventListener(evt, applyAgendamentos);
      agPeriodo.addEventListener(evt, applyAgendamentos);
      agTipo.addEventListener(evt, applyAgendamentos);
      agMesMonth.addEventListener(evt, applyAgendamentos);
      agMesYear.addEventListener(evt, applyAgendamentos);
    });

    // init
    (function initAgendamentoFiltro(){
      buildMonthYearOptions();

      // Restaura filtros salvos (para o botão "Atualizar" manter sua seleção)
      try{
        const raw = localStorage.getItem("ag_filters_v1");
        if(raw){
          const f = JSON.parse(raw);
          if(f && typeof f === "object"){
            if(typeof f.barber === "string") agBarberFilter.value = f.barber;
            if(typeof f.periodo === "string") agPeriodo.value = f.periodo;
            if(typeof f.tipo === "string") agTipo.value = f.tipo;
            if(typeof f.mm === "string") agMesMonth.value = f.mm;
            if(typeof f.yy === "string") agMesYear.value = f.yy;
          }
        }else{
          // defaults
          if (agPeriodo) agPeriodo.value = "hoje";
          if (agTipo) agTipo.value = "todos";
        }
      }catch(e){
        // defaults
        if (agPeriodo) agPeriodo.value = "hoje";
        if (agTipo) agTipo.value = "todos";
      }

      applyAgendamentos();
      updateAgLastUpdate();
    })();

    function updateAgLastUpdate(){
      const el = document.getElementById("agLastUpdate");
      if(!el) return;
      const d = new Date();
      el.textContent = `${pad2(d.getHours())}:${pad2(d.getMinutes())}:${pad2(d.getSeconds())}`;
    }

    function saveAgFilters(){
      try{
        const payload = {
          barber: agBarberFilter.value || "",
          periodo: agPeriodo.value || "hoje",
          tipo: agTipo.value || "todos",
          mm: agMesMonth.value || "",
          yy: agMesYear.value || ""
        };
        localStorage.setItem("ag_filters_v1", JSON.stringify(payload));
      }catch(e){}
    }

    // ===== Auto atualização (controlada por checkbox na aba Configuração) =====
    const AG_AUTO_KEY = "ag_auto_refresh_v1";
    const AG_AUTO_INTERVAL_SEC = 30;

    let agAutoTimer = null;
    let agAutoRemaining = AG_AUTO_INTERVAL_SEC;

    function setAutoRefreshUI(isOn){
      const cb = document.getElementById("agAutoRefreshToggle");
      if(cb) cb.checked = !!isOn;
      const next = document.getElementById("agNextRefresh");
      if(next) next.textContent = isOn ? `${agAutoRemaining}s` : "—";
    }

    function loadAutoRefreshSetting(){
      try{ return localStorage.getItem(AG_AUTO_KEY) === "1"; }catch(e){ return false; }
    }

    function saveAutoRefreshSetting(isOn){
      try{ localStorage.setItem(AG_AUTO_KEY, isOn ? "1" : "0"); }catch(e){}
    }

    function stopAutoRefresh(){
      if(agAutoTimer){
        clearInterval(agAutoTimer);
        agAutoTimer = null;
      }
      agAutoRemaining = AG_AUTO_INTERVAL_SEC;
      setAutoRefreshUI(loadAutoRefreshSetting());
    }

    function startAutoRefreshIfNeeded(){
      // Só roda se estiver habilitado e se a aba de agendamentos estiver ativa
      const isOn = loadAutoRefreshSetting();
      const agTab = document.getElementById("tabAgendamentos");
      const isAgActive = agTab && agTab.classList.contains("active");

      if(!isOn || !isAgActive){
        stopAutoRefresh();
        return;
      }

      if(agAutoTimer) return; // já rodando

      agAutoRemaining = AG_AUTO_INTERVAL_SEC;
      setAutoRefreshUI(true);

      agAutoTimer = setInterval(()=>{
        const agTabNow = document.getElementById("tabAgendamentos");
        const stillActive = agTabNow && agTabNow.classList.contains("active");
        const stillOn = loadAutoRefreshSetting();

        if(!stillOn || !stillActive){
          stopAutoRefresh();
          return;
        }

        agAutoRemaining -= 1;
        const next = document.getElementById("agNextRefresh");
        if(next) next.textContent = `${agAutoRemaining}s`;

        if(agAutoRemaining <= 0){
          // Recarrega mantendo filtros (mesma lógica do botão "Atualizar")
          saveAgFilters();
          const url = new URL(window.location.href);
          url.searchParams.set("tab", "agendamentos");
          url.searchParams.set("_t", String(Date.now()));
          window.location.href = url.toString();
        }
      }, 1000);
    }



    const agRefreshBtn = document.getElementById("agRefreshBtn");
    if(agRefreshBtn){
      agRefreshBtn.addEventListener("click", ()=>{
        // salva filtros e recarrega a página já voltando na aba de agendamentos
        saveAgFilters();
        const url = new URL(window.location.href);
        url.searchParams.set("tab", "agendamentos");
        // cache buster
        url.searchParams.set("_t", String(Date.now()));
        window.location.href = url.toString();
      });
    }


    // ===== CALENDÁRIO (manual) =====
    const admOverlay = document.getElementById("admOverlay");
    const admData = document.getElementById("admData");
    const admBarberId = document.getElementById("admBarberId");
    const admHorario = document.getElementById("admHorario");
    const admHorarioMsg = document.getElementById("admHorarioMsg");

    const admCalTitle = document.getElementById("admCalTitle");
    const admDays = document.getElementById("admDays");
    const admPrevMonth = document.getElementById("admPrevMonth");
    const admNextMonth = document.getElementById("admNextMonth");
    const admCancelCal = document.getElementById("admCancelCal");
    const admOkCal = document.getElementById("admOkCal");

    let calMonth = new Date();
    let selectedYMD = null;

    function openAdmCal(){
      const ymd = dmyToYMD(admData.value);
      if(ymd){
        selectedYMD = ymd;
        const d = parseYMD(ymd);
        if(d) calMonth = new Date(d.getFullYear(), d.getMonth(), 1);
      }else{
        const now = new Date();
        calMonth = new Date(now.getFullYear(), now.getMonth(), 1);
        selectedYMD = null;
      }
      admOverlay.classList.add("show");
      renderCal();
    }
    function closeAdmCal(){ admOverlay.classList.remove("show"); }

    function renderCal(){
      const y = calMonth.getFullYear();
      const m = calMonth.getMonth();
      const monthNames = ["Janeiro","Fevereiro","Março","Abril","Maio","Junho","Julho","Agosto","Setembro","Outubro","Novembro","Dezembro"];
      admCalTitle.textContent = `${monthNames[m]} ${y}`;

      const first = new Date(y, m, 1);
      const startDow = first.getDay();
      const daysInMonth = new Date(y, m+1, 0).getDate();

      const today = new Date();
      const todayStart = new Date(today.getFullYear(), today.getMonth(), today.getDate());
      const todayYMD = fmtYMD(todayStart);

      admDays.innerHTML = "";

      for(let i=0;i<startDow;i++){
        const div = document.createElement("div");
        div.className = "day muted";
        div.textContent = "";
        admDays.appendChild(div);
      }

      for(let d=1; d<=daysInMonth; d++){
        const dt = new Date(y, m, d);
        const ymd = fmtYMD(dt);
        const div = document.createElement("div");
        div.className = "day";
        div.textContent = String(d);

        if(dt < todayStart){
          div.classList.add("disabled");
        }else{
          div.addEventListener("click", ()=>{
            selectedYMD = ymd;
            renderCal();
          });
        }

        if(selectedYMD === ymd) div.classList.add("selected");
        if(!selectedYMD && ymd === todayYMD){
          selectedYMD = todayYMD;
          div.classList.add("selected");
        }

        admDays.appendChild(div);
      }
    }

    admPrevMonth.addEventListener("click", ()=>{ calMonth = new Date(calMonth.getFullYear(), calMonth.getMonth()-1, 1); renderCal(); });
    admNextMonth.addEventListener("click", ()=>{ calMonth = new Date(calMonth.getFullYear(), calMonth.getMonth()+1, 1); renderCal(); });
    admCancelCal.addEventListener("click", closeAdmCal);
    admOkCal.addEventListener("click", ()=>{
      if(!selectedYMD) { alert("Selecione uma data."); return; }

      const d = parseYMD(selectedYMD);
      admData.value = `${pad2(d.getDate())}/${pad2(d.getMonth()+1)}/${d.getFullYear()}`;

      closeAdmCal();
      refreshAdminHorarios();
    });

    admData.addEventListener("click", openAdmCal);

    async function refreshAdminHorarios(){
      admHorario.innerHTML = `<option value="">Selecione barbeiro e data</option>`;
      admHorario.disabled = true;
      admHorarioMsg.textContent = "";

      const b = admBarberId.value;
      const dmy = admData.value;
      if(!b || !dmy) return;

      const ymd = dmyToYMD(dmy);
      if(!ymd) return;

      try{
        const r = await fetch(`/horarios?barberId=${encodeURIComponent(b)}&data=${encodeURIComponent(ymd)}`);
        const slots = await r.json();

        let finalSlots = Array.isArray(slots) ? slots.slice() : [];

        const today = new Date();
        const todayYMD = fmtYMD(new Date(today.getFullYear(), today.getMonth(), today.getDate()));
        if(ymd === todayYMD){
          const nowMin = minutesNow();
          finalSlots = finalSlots.filter(h=>{
            const slotMin = timeToMinutes(h);
            return slotMin != null && (slotMin - nowMin) >= 10;
          });
        }

        if(!finalSlots.length){
          admHorario.innerHTML = `<option value="">Sem horários disponíveis</option>`;
          admHorario.disabled = true;
          admHorarioMsg.textContent = "Sem horários disponíveis.";
          return;
        }

        admHorario.innerHTML = `<option value="">Selecione</option>` + finalSlots.map(h=>`<option value="${h}">${h}</option>`).join("");
        admHorario.disabled = false;
      }catch(e){
        admHorarioMsg.textContent = "Erro ao carregar horários.";
      }
    }
    admBarberId.addEventListener("change", refreshAdminHorarios);

    /* Mensalistas JS */
    function todayYMDMen(){
      const t = new Date();
      return fmtYMD(new Date(t.getFullYear(), t.getMonth(), t.getDate()));
    }
    const menForm = document.getElementById("mensalistaForm");
    const menPlanId = document.getElementById("menPlanId");
    const menBarberId = document.getElementById("menBarberId");
    const menNome = document.getElementById("menNome");
    const menWeekday = document.getElementById("menWeekday");
    const menHorario = document.getElementById("menHorario");
    const menHorarioMsg = document.getElementById("menHorarioMsg");
    const menStart = document.getElementById("menStart");
    const menEnd = document.getElementById("menEnd");
    const menSubmitBtn = document.getElementById("menSubmitBtn");
    const menCancelEdit = document.getElementById("menCancelEdit");

    const menEditPill = document.getElementById("menEditPill");
    const menEditName = document.getElementById("menEditName");

    async function refreshMensalistaHorarios(){
      menHorario.innerHTML = `<option value="">Selecione barbeiro e dia da semana</option>`;
      menHorario.disabled = true;
      if(menHorarioMsg) menHorarioMsg.textContent = "";

      const b = menBarberId?.value;
      const wd = menWeekday?.value;
      if(!b || wd === "" || wd == null) return;

      if(menHorarioMsg) menHorarioMsg.textContent = "Carregando horários...";
      try{
        const r = await fetch(`/horarios_weekday?barberId=${encodeURIComponent(b)}&weekday=${encodeURIComponent(wd)}`);
        const slots = await r.json();

        if(!Array.isArray(slots) || slots.length === 0){
          menHorario.innerHTML = `<option value="">Sem horários disponíveis</option>`;
          menHorario.disabled = true;
          if(menHorarioMsg) menHorarioMsg.textContent = "Sem horários.";
          return;
        }

        menHorario.innerHTML = `<option value="">Selecione</option>` + slots.map(h => `<option value="${h}">${h}</option>`).join("");
        menHorario.disabled = false;
        if(menHorarioMsg) menHorarioMsg.textContent = "";
      }catch(e){
        if(menHorarioMsg) menHorarioMsg.textContent = "Erro ao carregar horários.";
      }
    }

    function setMensalistaEditMode(on, nomeLabel){
      if(on){
        menCancelEdit.style.display = "";
        menSubmitBtn.textContent = "Salvar edição";
        menEditPill.style.display = "";
        menEditName.textContent = nomeLabel || "";
      }else{
        menCancelEdit.style.display = "none";
        menSubmitBtn.textContent = "Salvar plano mensalista";
        menEditPill.style.display = "none";
        menEditName.textContent = "";
      }
    }

    function resetMensalistaForm(){
      if(menPlanId) menPlanId.value = "";
      menForm.action = "/admin/mensalistas";
      menBarberId.value = "";
      menNome.value = "";
      menWeekday.value = "";
      menHorario.innerHTML = `<option value="">Selecione barbeiro e dia da semana</option>`;
      menHorario.disabled = true;
      if(menHorarioMsg) menHorarioMsg.textContent = "";
      menStart.value = todayYMDMen();
      menEnd.value = "";
      setMensalistaEditMode(false);
    }

    window.startEditMensalista = async function(btn){
      const tr = btn?.closest("tr");
      if(!tr) return;

      const id = tr.dataset.menId;
      const barberId = tr.dataset.menBarberId;
      const nome = tr.dataset.menNome || "";
      const start = tr.dataset.menStart || "";
      const end = tr.dataset.menEnd || "";
      const weekday = tr.dataset.menWeekday || "";
      const horario = tr.dataset.menHorario || "";

      menPlanId.value = id || "";
      menBarberId.value = barberId || "";
      menNome.value = nome;
      menWeekday.value = weekday;

      menStart.value = start || todayYMDMen();
      menEnd.value = end || "";

      setMensalistaEditMode(true, nome);

      await refreshMensalistaHorarios();
      menHorario.value = horario;

      menForm.action = `/admin/mensalistas/${encodeURIComponent(id)}/update`;
      menForm.scrollIntoView({ behavior:"smooth", block:"start" });
    };

    menCancelEdit.addEventListener("click", resetMensalistaForm);
    menBarberId.addEventListener("change", refreshMensalistaHorarios);
    menWeekday.addEventListener("change", refreshMensalistaHorarios);

    // ===== Filtro de mensalistas por barbeiro =====
    const menBarberFilter = document.getElementById("menBarberFilter");
    const menTotal = document.getElementById("menTotal");

    function applyMenBarberFilter(){
      const v = menBarberFilter ? menBarberFilter.value : "";
      let shown = 0;

      document.querySelectorAll(".menRow").forEach(tr=>{
        const bid = tr.dataset.menBarberId || "";
        const ok = (!v) || (bid === v);
        tr.style.display = ok ? "" : "none";
        if(ok) shown++;
      });

      if(menTotal) menTotal.textContent = String(shown);
    }

    if(menBarberFilter){
      menBarberFilter.addEventListener("change", applyMenBarberFilter);
      // init
      setTimeout(applyMenBarberFilter, 0);
    }


    document.addEventListener("DOMContentLoaded", ()=>{
      // Inicializa checkbox de auto atualização (fica na aba Configuração)
      const cb = document.getElementById("agAutoRefreshToggle");
      if(cb){
        cb.checked = loadAutoRefreshSetting();
        cb.addEventListener("change", ()=>{
          saveAutoRefreshSetting(cb.checked);
          // se estiver na aba de agendamentos, liga/desliga na hora
          stopAutoRefresh();
          startAutoRefreshIfNeeded();
        });
      }
      // Atualiza UI do contador se existir
      setAutoRefreshUI(loadAutoRefreshSetting());

      if(menStart && !menStart.value) menStart.value = todayYMDMen();

      const tab = new URLSearchParams(window.location.search).get("tab");
      if(tab === "configgeral") activateTab("tabBtnBarbeiros");
      if(tab === "config") activateTab("tabBtnConfig");
      if(tab === "mensalistas") activateTab("tabBtnMensalistas");
      if(tab === "manual") activateTab("tabBtnManual");      if(tab === "agendamentos") activateTab("tabBtnAgendamentos");

      // Se já carregar direto em agendamentos e o auto estiver ligado, começa o contador
      startAutoRefreshIfNeeded();
    });
</script>
</body>
</html>
