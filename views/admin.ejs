<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <title>Painel Admin</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <style>
    :root{
      --bg0:#070707;
      --bg1:#0c0c0c;
      --card:#0f0f0f;
      --card2:#121212;
      --line:#262626;
      --line2:#1f1f1f;

      --txt:#f5f5f5;
      --muted:#b9b9b9;

      --gold:#c9a227;
      --gold2:#e0bf4a;

      --green:#19c37d;
      --red:#ff3b4d;

      --shadow: 0 18px 50px rgba(0,0,0,.55);
      --radius:16px;
    }

    *{ box-sizing:border-box; }
    html, body{ height:100%; }
    body{
      margin:0;
      font-family: Arial, sans-serif;
      color:var(--txt);
      background:
        radial-gradient(1200px 700px at 20% -10%, rgba(201,162,39,.12), transparent 60%),
        radial-gradient(900px 500px at 90% 0%, rgba(25,195,125,.08), transparent 55%),
        linear-gradient(180deg, var(--bg0), var(--bg1));
    }

    header{
      position: sticky;
      top: 0;
      z-index: 50;
      background: rgba(10,10,10,.78);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(201,162,39,.18);
      padding: 14px 16px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
    }
    header strong{
      font-size: 15px;
      letter-spacing:.4px;
    }

    main{
      max-width:1100px;
      margin:18px auto;
      padding:0 16px;
    }

    .grid{
      display:grid;
      grid-template-columns:1fr;
      gap:16px;
    }

    .card{
      background: linear-gradient(180deg, rgba(18,18,18,.96), rgba(13,13,13,.96));
      border: 1px solid rgba(201,162,39,.14);
      border-radius: var(--radius);
      padding: 16px;
      box-shadow: var(--shadow);
    }

    h2{
      margin:0 0 10px 0;
      font-size: 18px;
      letter-spacing:.2px;
    }
    h3{
      margin:0 0 10px 0;
      font-size: 15px;
      color: var(--gold2);
      letter-spacing:.2px;
    }

    .muted{
      color: var(--muted);
      font-size: 12px;
      font-weight: 800;
      line-height: 1.35;
    }
    .bad{
      color: #ff6b78;
      font-weight: 900;
    }

    .row{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      align-items:center;
    }

    .pill{
      padding: 6px 10px;
      border-radius: 999px;
      background: rgba(255,255,255,.06);
      border: 1px solid rgba(255,255,255,.10);
      font-size: 12px;
      font-weight: 900;
      color: var(--txt);
    }

    .tag{
      border:1px solid rgba(255,255,255,.12);
      background: rgba(255,255,255,.06);
      color: var(--txt);
      border-radius:999px;
      padding: 7px 10px;
      font-size: 12px;
      font-weight: 900;
    }
    .tag.confirmado{
      border-color: rgba(25,195,125,.55);
      box-shadow: 0 0 0 2px rgba(25,195,125,.12);
    }
    .tag.reservado{
      border-color: rgba(201,162,39,.65);
      box-shadow: 0 0 0 2px rgba(201,162,39,.14);
    }
    .tag.mensalista{
      border-color: rgba(255,255,255,.18);
      box-shadow: 0 0 0 2px rgba(255,255,255,.08);
    }

    label{
      font-weight: 900;
      display:block;
      margin-top: 10px;
      margin-bottom: 6px;
      font-size: 12px;
      color: var(--muted);
      letter-spacing:.2px;
    }
    input, select{
      width: 100%;
      padding: 11px 12px;
      border-radius: 12px;
      border: 1px solid rgba(255,255,255,.14);
      background: rgba(255,255,255,.06);
      color: var(--txt);
      outline: none;
      font-weight: 900;
    }
    input::placeholder{ color: rgba(245,245,245,.45); font-weight: 800; }
    input:focus, select:focus{
      border-color: rgba(201,162,39,.7);
      box-shadow: 0 0 0 3px rgba(201,162,39,.14);
    }
    select option{
      background: #0e0e0e;
      color: var(--txt);
    }

    input[type="checkbox"]{
      width:auto;
      accent-color: var(--gold);
      transform: translateY(1px);
    }

    .btn{
      padding: 11px 14px;
      border-radius: 12px;
      border: 1px solid rgba(255,255,255,.14);
      cursor: pointer;
      background: rgba(255,255,255,.06);
      color: var(--txt);
      font-weight: 900;
      transition: transform .05s ease, background .15s ease, border-color .15s ease, box-shadow .15s ease;
      white-space: nowrap;
    }
    .btn:hover{
      border-color: rgba(201,162,39,.45);
      box-shadow: 0 10px 25px rgba(0,0,0,.28);
      transform: translateY(-1px);
    }
    .btn:active{ transform: translateY(0px); }

    .btnPrimary{
      background: linear-gradient(180deg, var(--gold2), var(--gold));
      color: #111;
      border: none;
    }
    .btnPrimary:hover{
      box-shadow: 0 12px 30px rgba(201,162,39,.22);
      transform: translateY(-1px);
    }

    .btnWarn{
      background: linear-gradient(180deg, rgba(201,162,39,.95), rgba(201,162,39,.8));
      color: #111;
      border: none;
    }

    .btnDanger{
      background: linear-gradient(180deg, rgba(255,59,77,.95), rgba(176,0,32,.92));
      color:#fff;
      border: none;
    }

    .cols{
      display:grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
    .full{ grid-column: 1 / -1; }

    @media (max-width: 800px){
      .cols{ grid-template-columns: 1fr; }
    }

    .tabs{
      max-width:1100px;
      margin: 14px auto 0;
      padding: 0 16px;
      display:flex;
      gap: 10px;
      flex-wrap: wrap;
      align-items:center;
    }
    .tabBtn{
      border: 1px solid rgba(255,255,255,.14);
      background: rgba(255,255,255,.06);
      color: var(--txt);
      border-radius: 999px;
      padding: 10px 14px;
      cursor:pointer;
      font-weight: 900;
      transition: background .15s ease, border-color .15s ease, transform .05s ease;
    }
    .tabBtn:hover{
      border-color: rgba(201,162,39,.45);
      transform: translateY(-1px);
    }
    .tabBtn.active{
      background: linear-gradient(180deg, rgba(201,162,39,.95), rgba(201,162,39,.75));
      color:#111;
      border: none;
    }
    .tabPanel{ display:none; }
    .tabPanel.active{ display:block; }

    table{
      width:100%;
      border-collapse: collapse;
      font-size: 14px;
      overflow:hidden;
      border-radius: 14px;
      border: 1px solid rgba(255,255,255,.10);
      background: rgba(255,255,255,.03);
    }
    th, td{
      padding: 12px 10px;
      text-align:left;
      vertical-align: middle;
      border-bottom: 1px solid rgba(255,255,255,.06);
    }
    thead th{
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: .6px;
      color: rgba(245,245,245,.75);
      background: rgba(255,255,255,.04);
    }
    tbody tr:hover{
      background: rgba(201,162,39,.06);
    }

    .agendaWrap{
      display:grid;
      grid-template-columns: 1fr;
      gap: 12px;
    }
    .dayCard{
      border: 1px solid rgba(201,162,39,.14);
      border-radius: 16px;
      overflow:hidden;
      background: rgba(255,255,255,.03);
    }
    .dayHeader{
      padding: 12px 14px;
      background: linear-gradient(180deg, rgba(15,15,15,.95), rgba(10,10,10,.95));
      border-bottom: 1px solid rgba(201,162,39,.12);
      display:flex;
      align-items:center;
      justify-content: space-between;
      gap: 10px;
      flex-wrap: wrap;
    }
    .dayHeader strong{
      font-size: 14px;
      letter-spacing:.4px;
      color: var(--gold2);
    }
    .countBadge{
      background: rgba(201,162,39,.16);
      border: 1px solid rgba(201,162,39,.28);
      color: var(--gold2);
      font-weight: 900;
      padding: 7px 10px;
      border-radius: 999px;
      font-size: 12px;
    }
    .slotList{
      padding: 10px 12px 12px;
      display:grid;
      grid-template-columns: 1fr;
      gap: 10px;
    }
    .slotItem{
      border: 1px solid rgba(255,255,255,.10);
      border-radius: 14px;
      padding: 10px 12px;
      display:flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 10px;
      flex-wrap: wrap;
      background: rgba(255,255,255,.03);
    }
    .slotLeft{
      display:flex;
      gap: 10px;
      align-items:center;
      flex-wrap:wrap;
      min-width: 240px;
    }
    .timePill{
      background: rgba(201,162,39,.18);
      border: 1px solid rgba(201,162,39,.30);
      color: var(--gold2);
      font-weight: 900;
      padding: 7px 10px;
      border-radius: 999px;
      font-size: 12px;
      min-width: 78px;
      text-align:center;
    }
    .info{
      display:flex;
      flex-direction: column;
      gap: 4px;
      font-size: 13px;
      font-weight: 900;
      color: var(--txt);
    }
    .info small{
      font-weight: 900;
      color: rgba(245,245,245,.65);
    }
    .slotRight{
      display:flex;
      gap: 8px;
      flex-wrap: wrap;
      align-items:center;
      justify-content:flex-end;
    }

    .monthPickerBox{
      display:flex;
      gap: 8px;
      align-items:center;
      flex-wrap: nowrap;
    }
    .monthPickerBox select{
      background: rgba(255,255,255,.06);
      color: var(--txt);
      border: 1px solid rgba(255,255,255,.14);
      border-radius: 12px;
      padding: 11px 12px;
      font-weight: 900;
      min-width: 150px;
    }
    .monthPickerBox select:focus{
      outline: none;
      box-shadow: 0 0 0 3px rgba(201,162,39,.14);
      border-color: rgba(201,162,39,.7);
    }

    .overlay{
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,.70);
      display: none;
      align-items:center;
      justify-content:center;
      padding: 18px;
      z-index: 999;
    }
    .overlay.show{ display:flex; }

    #admOverlay{
      z-index: 3000;
    }
    #swapOverlay{
      z-index: 2000;
    }

    .cal{
      width: 380px;
      max-width: 100%;
      background: linear-gradient(180deg, rgba(16,16,16,.98), rgba(10,10,10,.98));
      border: 1px solid rgba(201,162,39,.18);
      border-radius: 18px;
      overflow:hidden;
      box-shadow: 0 18px 55px rgba(0,0,0,.65);
      color: var(--txt);
    }
    .calWide{
      width: 480px;
    }
    .cal-head{
      display:flex;
      align-items:center;
      justify-content: space-between;
      padding: 12px 12px;
      background: rgba(255,255,255,.03);
      border-bottom: 1px solid rgba(255,255,255,.08);
    }
    .cal-title{
      font-weight: 900;
      color: var(--gold2);
      font-size: 14px;
      letter-spacing:.3px;
    }
    .cal-nav{ display:flex; gap: 8px; }
    .cal-nav button{
      border: 1px solid rgba(255,255,255,.14);
      background: rgba(255,255,255,.06);
      color: var(--txt);
      border-radius: 12px;
      padding: 8px 10px;
      cursor:pointer;
      font-weight: 900;
    }
    .cal-body{ padding: 12px; }
    .dow{
      display:grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 6px;
      margin-bottom: 8px;
      font-size: 11px;
      color: rgba(245,245,245,.65);
      text-align:center;
      font-weight: 900;
    }
    .days{
      display:grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 6px;
    }
    .day{
      border: 1px solid rgba(255,255,255,.12);
      background: rgba(255,255,255,.05);
      color: var(--txt);
      border-radius: 12px;
      padding: 10px 0;
      text-align:center;
      cursor:pointer;
      font-weight: 900;
      user-select:none;
    }
    .day.muted{ opacity:.28; cursor: default; }
    .day.disabled{ opacity:.22; cursor: not-allowed; }
    .day.selected{
      border-color: rgba(201,162,39,.8);
      box-shadow: 0 0 0 3px rgba(201,162,39,.14);
      background: rgba(201,162,39,.10);
    }
    .cal-foot{
      display:flex;
      gap: 10px;
      padding: 12px;
      border-top: 1px solid rgba(255,255,255,.08);
      background: rgba(255,255,255,.03);
    }
    .cal-foot button{
      flex: 1;
      border-radius: 12px;
      padding: 12px;
      cursor:pointer;
      font-weight: 900;
      border: 1px solid rgba(255,255,255,.14);
      background: rgba(255,255,255,.06);
      color: var(--txt);
    }
    .cal-foot button.primary{
      background: linear-gradient(180deg, var(--gold2), var(--gold));
      color:#111;
      border: none;
    }

    form{ margin:0; }
    hr{ border:0; border-top: 1px solid rgba(255,255,255,.08); margin: 18px 0; }

    .tag{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding: 6px 10px;
      border-radius:999px;
      font-size: 12px;
      font-weight: 900;
      letter-spacing: .2px;
      line-height: 1;
    }

    .tag::before{
      content:"";
      width:8px;
      height:8px;
      border-radius:999px;
      box-shadow: 0 0 0 2px rgba(0,0,0,.35);
    }

    .tag.confirmado{
      background: rgba(25,195,125,.10);
      border-color: rgba(25,195,125,.55);
      box-shadow: 0 0 0 2px rgba(25,195,125,.10);
    }
    .tag.confirmado::before{ background: var(--green); }

    .tag.reservado{
      background: rgba(201,162,39,.10);
      border-color: rgba(201,162,39,.65);
      box-shadow: 0 0 0 2px rgba(201,162,39,.12);
    }
    .tag.reservado::before{ background: var(--gold2); }

    .tag.mensalista{
      background: rgba(255,255,255,.06);
      border-color: rgba(255,255,255,.18);
      box-shadow: 0 0 0 2px rgba(255,255,255,.06);
    }
    .tag.mensalista::before{ background: rgba(245,245,245,.75); }

    .btnMini{
      padding: 7px 10px;
      border-radius: 999px;
      font-size: 12px;
      line-height: 1;
    }

    .btnConfirm{
      background: linear-gradient(180deg, rgba(201,162,39,.95), rgba(201,162,39,.80));
      color: #111;
      border: none;
    }
    .btnConfirm:hover{
      box-shadow: 0 12px 30px rgba(201,162,39,.18);
      transform: translateY(-1px);
    }

    .btnCancel{
      background: rgba(255,59,77,.06);
      border: 1px solid rgba(255,59,77,.35);
      color: #ffd7db;
    }
    .btnCancel:hover{
      border-color: rgba(255,59,77,.60);
      box-shadow: 0 10px 24px rgba(0,0,0,.25);
    }

    .btnSwap{
      background: rgba(255,59,77,.06);
      border: 1px solid rgba(255,59,77,.35);
      color: #ffd7db;
    }
    .btnSwap:hover{
      border-color: rgba(255,59,77,.60);
      box-shadow: 0 10px 24px rgba(0,0,0,.25);
    }

    .swapInfo{
      display:grid;
      gap:8px;
      margin-bottom: 10px;
      padding: 10px 12px;
      border-radius: 14px;
      border: 1px solid rgba(255,255,255,.10);
      background: rgba(255,255,255,.03);
      font-size: 13px;
      font-weight: 900;
    }
    .notifBox{
      margin-top: 12px;
      padding: 14px;
      border-radius: 14px;
      border: 1px solid rgba(255,255,255,.10);
      background: rgba(255,255,255,.03);
      display: grid;
      gap: 10px;
    }

    .notifStatus{
      font-size: 13px;
      font-weight: 900;
      color: var(--txt);
    }

    .notifStatus.ok{ color: var(--green); }
    .notifStatus.warn{ color: var(--gold2); }
    .notifStatus.err{ color: #ff8a96; }

    .notifActions{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
    }
  </style>
</head>

<body>
  <%
    function ymdToDmy(ymd) {
      if (!ymd || typeof ymd !== "string") return "";
      const m = ymd.match(/^(\d{4})-(\d{2})-(\d{2})$/);
      if (!m) return ymd;
      return `${m[3]}-${m[2]}-${m[1]}`;
    }

    function ymdToDmyWithWeekday(ymd) {
      if (!ymd || typeof ymd !== "string") return "";
      const m = ymd.match(/^(\d{4})-(\d{2})-(\d{2})$/);
      if (!m) return ymd;

      const year = Number(m[1]);
      const month = Number(m[2]);
      const day = Number(m[3]);

      const dt = new Date(year, month - 1, day);

      const weekdays = [
        "Domingo",
        "Segunda-feira",
        "Terça-feira",
        "Quarta-feira",
        "Quinta-feira",
        "Sexta-feira",
        "Sábado"
      ];

      return `${m[3]}/${m[2]}/${m[1]} - ${weekdays[dt.getDay()]}`;
    }

    function weekdayLabel(n){
      const map = ["Domingo","Segunda","Terça","Quarta","Quinta","Sexta","Sábado"];
      return map[Number(n)] ?? String(n);
    }

    function onlyDigits(value){
      return String(value || "").replace(/\D/g, "");
    }

    function formatPhoneDisplay(value){
      const digits = onlyDigits(value);
      if(!digits) return "";
      if(digits.length === 13 && digits.startsWith("55")){
        return `${digits.slice(0,2)} ${digits.slice(2,4)} ${digits.slice(4,9)}-${digits.slice(9)}`;
      }
      if(digits.length === 11){
        return `${digits.slice(0,2)} ${digits.slice(2,7)}-${digits.slice(7)}`;
      }
      return digits;
    }

    function formatCentsBRL(cents){
      const value = Number(cents || 0) / 100;
      return value.toLocaleString("pt-BR", {
        style: "currency",
        currency: "BRL"
      });
    }

    const agendaBase = (agendamentos || []).filter(a => a.status === "aprovado" || a.status === "reservado");
    const agendaAll = agendaBase.concat(mensalistaConfirmados || []);

    const agendaByDate = {};
    agendaAll.forEach(a => {
      const key = a.data || "";
      if (!agendaByDate[key]) agendaByDate[key] = [];
      agendaByDate[key].push(a);
    });

    const agendaDates = Object.keys(agendaByDate).sort((a,b) => String(a).localeCompare(String(b)));
    agendaDates.forEach(d => agendaByDate[d].sort((x,y) => String(x.horario).localeCompare(String(y.horario))));

    const expMin = (typeof reservaExpiraMinutos !== "undefined" && reservaExpiraMinutos !== null)
      ? Number(reservaExpiraMinutos)
      : 30;

    const agRefreshSec = (typeof agendamentosRefreshSegundos !== "undefined" && agendamentosRefreshSegundos !== null)
      ? Number(agendamentosRefreshSegundos)
      : 30;

    const servicesList = Array.isArray(services) ? services : [];

    const selectedCfgBarberId = Number(selectedConfigBarberId || 0);
    const selectedCfgBarberObj = selectedConfigBarber || null;
    const selectedCfg = selectedCfgBarberId && barberConfigs ? barberConfigs[selectedCfgBarberId] : null;
    const selectedCfgDaysOff = selectedCfg ? (selectedCfg.daysOffDates || []).map(ymdToDmy).join(", ") : "";
  %>

  <header>
    <div class="row" style="gap:12px;">
      <div>
        <strong>Painel Admin</strong>
        <div class="muted" style="margin-top:2px;">Gestão de barbeiros, mensalistas e agenda</div>
      </div>
      <span class="pill">logado: <%= adminUser?.username %></span>
    </div>

    <form method="POST" action="/admin/logout">
      <button class="btn btnPrimary" type="submit">Sair</button>
    </form>
  </header>

  <div class="tabs">
    <button class="tabBtn active" id="tabBtnBarbeiros" type="button">Configuração</button>
    <button class="tabBtn" id="tabBtnConfig" type="button">Config por barbeiros</button>
    <button class="tabBtn" id="tabBtnMensalistas" type="button">Plano mensalista</button>
    <button class="tabBtn" id="tabBtnManual" type="button">Agendar manualmente</button>
    <button class="tabBtn" id="tabBtnAgendamentos" type="button">Agendamentos</button>
  </div>

  <main>
    <div class="tabPanel active" id="tabBarbeiros">
      <div class="grid">

        <div class="card">
          <h2>Configuração</h2>
          <div class="muted">
            O tempo abaixo controla em quantos minutos um agendamento <strong>reservado</strong> expira
            (se o cliente não confirmar no WhatsApp). Depois disso, ele é removido do banco.
          </div>

<form method="POST" action="/admin/config/reserva" style="margin-top:12px;">
  <div class="cols">
    <div>
      <label>Tempo para expirar reserva (minutos)</label>
      <input type="number" name="reservaExpiraMinutos" min="1" max="720" value="<%= expMin %>" required />
      <div class="muted">Padrão: 30. Máximo: 720 (12h).</div>
    </div>

    <div>
      <label>Atualização automática da aba Agendamentos (minutos)</label>
      <input
      type="number"
      name="agendamentosRefreshMinutos"
      min="1"
      max="60"
      value="<%= Math.ceil(agRefreshSec / 60) %>"
      required
      />
    <div class="muted">Ex.: 1 = 1 minuto, 10 = 10 minutos.</div>
    </div>

    <div class="full" style="display:flex; align-items:flex-end;">
      <button class="btn btnPrimary" type="submit" style="width:100%;">Salvar</button>
    </div>
  </div>
</form>

<div class="notifBox">
  <div>
    <h3 style="margin-bottom:6px;">Notificações no celular / tablet</h3>
    <div class="muted">
      Ative para receber aviso quando um cliente confirmar ou cancelar um horário,
      mesmo com o painel em segundo plano.
    </div>
  </div>

  <div id="pushStatus" class="notifStatus warn">
    Verificando suporte do dispositivo...
  </div>

  <div class="notifActions">
    <button type="button" class="btn btnPrimary" id="btnAtivarPush">
      Ativar notificações
    </button>

    <button type="button" class="btn" id="btnDesativarPush" style="display:none;">
      Desativar neste aparelho
    </button>
  </div>
</div>
