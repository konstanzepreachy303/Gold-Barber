                        const isConfirmado = (!isMensalista && st === "aprovado");
                        const isReservado = (!isMensalista && st === "reservado");
                        const tagClass = isMensalista ? "mensalista" : (isConfirmado ? "confirmado" : "reservado");
                        const tagText = isMensalista ? "mensalista" : (isConfirmado ? "confirmado" : "reservado");
                        const planId = isMensalista ? String(a.id || "").replace(/^m\-([^\-]+)\-.+$/, "$1") : "";
                        const serviceLabel = a.service_name || "";
                        const servicePriceLabel = Number(a.service_price_cents || 0) > 0 ? formatCentsBRL(a.service_price_cents) : "";
                      %>

                      <div
                        class="slotItem agSlot"
                        data-id="<%= a.id %>"
                        data-barber-id="<%= a.barber_id %>"
                        data-status="<%= st %>"
                        data-is-mensalista="<%= isMensalista ? '1' : '0' %>"
                        data-plan-id="<%= planId %>"
                        data-date="<%= a.data %>"
                        data-horario="<%= a.horario %>"
                        data-nome="<%- String(a.nome || '').replace(/\"/g, '&quot;') %>"
                        data-barber-name="<%- String(a.barber_name || '').replace(/\"/g, '&quot;') %>"
                      >
                        <div class="slotLeft">
                          <span class="timePill"><%= a.horario %></span>
                          <div class="info">
                            <div><%= a.nome %></div>
                            <small>Barbeiro: <%= a.barber_name || "" %></small>
                            <% if (serviceLabel) { %>
                              <small>Serviço: <%= serviceLabel %><%= servicePriceLabel ? ` • ${servicePriceLabel}` : "" %></small>
                            <% } %>
                          </div>
                        </div>

                        <div class="slotRight">
                          <span class="tag <%= tagClass %>"><%= tagText %></span>

                          <% if (isMensalista) { %>
                            <button class="btn btnMini btnSwap" type="button" onclick="abrirTrocaMensalista(this)">
                              Trocar horário
                            </button>
                          <% } %>

                          <% if (isReservado) { %>
                            <button class="btn btnMini btnConfirm" type="button" onclick="confirmarManual(<%= a.id %>)">
                              Confirmar
                            </button>
                          <% } %>

                          <% if (!isMensalista) { %>
                            <button class="btn btnMini btnCancel" type="button" onclick="cancelarAg(<%= a.id %>)">Cancelar</button>
                          <% } %>
                        </div>
                      </div>
                    <% }) %>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </main>

  <div id="admOverlay" class="overlay" aria-hidden="true">
    <div class="cal" role="dialog" aria-modal="true" aria-label="Selecionar data">
      <div class="cal-head">
        <div class="cal-title" id="admCalTitle">Mês</div>
        <div class="cal-nav">
          <button type="button" id="admPrevMonth">◀</button>
          <button type="button" id="admNextMonth">▶</button>
        </div>
      </div>
      <div class="cal-body">
        <div class="dow">
          <div>DOM</div><div>SEG</div><div>TER</div><div>QUA</div><div>QUI</div><div>SEX</div><div>SÁB</div>
        </div>
        <div id="admDays" class="days"></div>
      </div>
      <div class="cal-foot">
        <button type="button" id="admCancelCal">Cancelar</button>
        <button type="button" class="primary" id="admOkCal">Confirmar</button>
      </div>
    </div>
  </div>

  <div id="swapOverlay" class="overlay" aria-hidden="true">
    <div class="cal calWide" role="dialog" aria-modal="true" aria-label="Trocar horário do mensalista">
      <div class="cal-head">
        <div class="cal-title">Trocar horário do mensalista</div>
      </div>
      <div class="cal-body">
        <div class="swapInfo">
          <div>Cliente: <span id="swapNome">—</span></div>
          <div>Barbeiro: <span id="swapBarbeiro">—</span></div>
          <div>Ocorrência atual: <span id="swapAtual">—</span></div>
        </div>

        <form method="POST" action="/admin/mensalistas/trocar-horario" id="swapMensalistaForm">
          <input type="hidden" name="planId" id="swapPlanId" />
          <input type="hidden" name="barberId" id="swapBarberId" />
          <input type="hidden" name="originalDate" id="swapOriginalDate" />
          <input type="hidden" name="originalHorario" id="swapOriginalHorario" />

          <div class="cols">
            <div>
              <label>Nova data</label>
              <input type="text" name="newDateDisplay" id="swapDateDisplay" placeholder="Clique para escolher" readonly style="cursor:pointer;" />
              <input type="hidden" name="newDate" id="swapDate" />
            </div>

            <div>
              <label>Novo horário</label>
              <select name="newHorario" id="swapHorario" required disabled>
                <option value="">Selecione a nova data</option>
              </select>
              <div class="muted" id="swapHorarioMsg"></div>
            </div>

            <div class="full">
              <div class="muted">
                O sistema deve validar se o barbeiro trabalha no novo dia e se o novo horário está livre.
              </div>
            </div>
          </div>
        </form>
      </div>
      <div class="cal-foot">
        <button type="button" id="swapCancelBtn">Cancelar</button>
        <button type="submit" form="swapMensalistaForm" class="primary">Salvar troca</button>
      </div>
    </div>
  </div>

  <script>
    function pad2(n){ return String(n).padStart(2, "0"); }
    function fmtYMD(d){ return `${d.getFullYear()}-${pad2(d.getMonth()+1)}-${pad2(d.getDate())}`; }
    function fmtDMY(d){ return `${pad2(d.getDate())}-${pad2(d.getMonth()+1)}-${d.getFullYear()}`; }
    function fmtDMYSlash(d){ return `${pad2(d.getDate())}/${pad2(d.getMonth()+1)}/${d.getFullYear()}`; }

    function addDays(d, days){ const x = new Date(d.getTime()); x.setDate(x.getDate()+days); return x; }
    function parseYMD(ymd){
      if(!ymd) return null;
      const m = String(ymd).match(/^(\d{4})-(\d{2})-(\d{2})$/);
      if(!m) return null;
      return new Date(Number(m[1]), Number(m[2])-1, Number(m[3]));
    }
    function dmyToYMD(dmy){
      if(!dmy) return null;
      const m = String(dmy).match(/^(\d{2})[\/\-](\d{2})[\/\-](\d{4})$/);
      if(!m) return null;
      return `${m[3]}-${m[2]}-${m[1]}`;
    }
    function minutesNow(){
      const n = new Date();
      return n.getHours() * 60 + n.getMinutes();
    }
    function timeToMinutes(hhmm){
      const m = String(hhmm || "").match(/^(\d{2}):(\d{2})$/);
      if(!m) return null;
      return Number(m[1]) * 60 + Number(m[2]);
    }
    function calcMensalistaEnd(startYMD){
      const dt = parseYMD(startYMD);
      if(!dt) return "";
      return fmtYMD(addDays(dt, 21));
    }
    function weekdayFromYMD(ymd){
      const dt = parseYMD(ymd);
      return dt ? String(dt.getDay()) : "";
    }
    function ymdToSlash(ymd){
      const d = parseYMD(ymd);
      return d ? fmtDMYSlash(d) : "";
    }

    const tabs = [
      { btn: "tabBtnBarbeiros", panel:"tabBarbeiros" },
      { btn: "tabBtnConfig", panel:"tabConfig" },
      { btn: "tabBtnMensalistas", panel:"tabMensalistas" },
      { btn: "tabBtnManual", panel:"tabManual" },
      { btn: "tabBtnAgendamentos", panel:"tabAgendamentos" },
    ];

    function activateTab(btnId){
      tabs.forEach(t=>{
        const b = document.getElementById(t.btn);
        const p = document.getElementById(t.panel);
        const active = (t.btn === btnId);
        b.classList.toggle("active", active);
        p.classList.toggle("active", active);
      });
      if(btnId === "tabBtnAgendamentos") applyAgendamentos();
      stopAutoRefresh();
      startAutoRefreshIfNeeded();
      if(btnId === "tabBtnMensalistas"){
        if(menStart && !menStart.value) menStart.value = fmtDMYSlash(new Date());
        updateMensalistaDateFields();
      }
    }
    tabs.forEach(t=>{
      document.getElementById(t.btn).addEventListener("click", ()=>activateTab(t.btn));
    });

    async function updateStatus(id, status){
      const r = await fetch("/admin/status", {
        method:"POST",
        headers:{ "Content-Type":"application/json" },
        body: JSON.stringify({ id, status })
      });
      const j = await r.json();
      if(!j.ok) throw new Error("fail");
    }

    window.confirmarManual = async function(id){
      if(!confirm("Confirmar manualmente este agendamento?")) return;
      try{
        await updateStatus(id, "aprovado");
        const el = document.querySelector(`.agSlot[data-id="${id}"]`);
        if(el) el.dataset.status = "aprovado";
        applyAgendamentos();
      }catch(e){ alert("Erro ao confirmar."); }
    };

    window.cancelarAg = async function(id){
      if(!confirm("Cancelar este agendamento?")) return;
      try{
        await updateStatus(id, "cancelado");
        const el = document.querySelector(`.agSlot[data-id="${id}"]`);
        if(el) el.dataset.status = "cancelado";
        applyAgendamentos();
      }catch(e){ alert("Erro ao cancelar."); }
    };

    const agBarberFilter = document.getElementById("agBarberFilter");
    const agPeriodo = document.getElementById("agPeriodo");
    const agTipo = document.getElementById("agTipo");
    const agMesWrap = document.getElementById("agMesWrap");
    const agMesMonth = document.getElementById("agMesMonth");
    const agMesYear = document.getElementById("agMesYear");
    const agPeriodoLabel = document.getElementById("agPeriodoLabel");
    const agHint = document.getElementById("agHint");
    const agTotal = document.getElementById("agTotal");

    function lastDayOfMonth(d){
      return new Date(d.getFullYear(), d.getMonth() + 1, 0);
    }

    function buildMonthYearOptions(){
      const now = new Date();
      const currentYear = now.getFullYear();
      const startY = currentYear - 2;
      const endY = currentYear + 3;

      agMesYear.innerHTML =
        `<option value="">Ano</option>` +
        Array.from({length: (endY-startY+1)}, (_,i)=>{
          const y = startY + i;
          return `<option value="${y}">${y}</option>`;
        }).join("");
    }

    function rangeForPeriodo(){
      const now = new Date();
      const p = agPeriodo.value;

      if (p === "hoje"){
        const ymd = fmtYMD(now);
        return { start: ymd, end: ymd, label: `Hoje (${fmtDMY(now)})`, incomplete:false };
      }
      if (p === "semana"){
        const todayStart = new Date(now.getFullYear(), now.getMonth(), now.getDate());
        const dow = todayStart.getDay();
        const daysToSat = (6 - dow + 7) % 7;
        const sat = addDays(todayStart, daysToSat);
        return {
          start: fmtYMD(todayStart),
          end: fmtYMD(sat),
          label: `Semana (hoje → Sáb): ${fmtDMY(todayStart)} → ${fmtDMY(sat)}`,
          incomplete:false
        };
      }
      if (p === "mes"){
        const end = lastDayOfMonth(now);
        return {
          start: fmtYMD(now),
          end: fmtYMD(end),
          label: `Mês (hoje → fim): ${fmtDMY(now)} → ${fmtDMY(end)}`,
          incomplete:false
        };
      }

      const mm = agMesMonth.value;
      const yy = agMesYear.value;
      if (!mm || !yy){
        return {
          start: "",
          end: "",
          label: "Mês inteiro: selecione o mês e o ano.",
          incomplete:true
        };
      }

      const yearNum = Number(yy);
      const monthNum = Number(mm);
      const first = new Date(yearNum, monthNum - 1, 1);
      const last = new Date(yearNum, monthNum, 0);

      return {
        start: fmtYMD(first),
        end: fmtYMD(last),
        label: `Mês inteiro: ${fmtDMY(first)} → ${fmtDMY(last)}`,
        incomplete:false
      };
    }

    function tipoMatches(slotEl){
      const isMensalista = slotEl.dataset.isMensalista === "1";
      const st = slotEl.dataset.status || "";

      const t = agTipo.value;
      if (t === "todos") return true;
      if (t === "mensalista") return isMensalista;
      if (t === "confirmado") return !isMensalista && st === "aprovado";
      if (t === "reservado") return !isMensalista && st === "reservado";
      return true;
    }

    function applyAgendamentos(){
      const bId = agBarberFilter.value;
      agHint.style.display = bId ? "none" : "";

      if (agPeriodo.value === "mes_inteiro"){
        agMesWrap.style.display = "";
      } else {
        agMesWrap.style.display = "none";
      }

      const { start, end, label, incomplete } = rangeForPeriodo();
      if (agPeriodoLabel) agPeriodoLabel.textContent = label;

      let totalShown = 0;

      document.querySelectorAll(".agDayCard").forEach(card=>{
        const dateKey = card.dataset.date;

        let inRange = !!bId;

        if (inRange && agPeriodo.value === "mes_inteiro" && incomplete){
          inRange = false;
        }

        if (inRange && start && dateKey < start) inRange = false;
        if (inRange && end && dateKey > end) inRange = false;

        let dayCount = 0;

        card.querySelectorAll(".agSlot").forEach(slot=>{
          const sb = slot.dataset.barberId;
          const st = slot.dataset.status || "";

          if(st === "cancelado"){
            slot.style.display = "none";
            return;
          }

          let ok = true;
          if(!inRange) ok = false;
          if(ok && sb !== bId) ok = false;
          if (!tipoMatches(slot)) ok = false;

          slot.style.display = ok ? "" : "none";
          if(ok){ dayCount++; totalShown++; }

          const isMen = slot.dataset.isMensalista === "1";
          const tag = slot.querySelector(".tag");
          const btnConfirm = slot.querySelector(".btnConfirm");

          if(tag){
            if(isMen){
              tag.className = "tag mensalista";
              tag.textContent = "mensalista";
              if(btnConfirm) btnConfirm.style.display = "none";
            }else if(st === "aprovado"){
              tag.className = "tag confirmado";
              tag.textContent = "confirmado";
              if(btnConfirm) btnConfirm.style.display = "none";
            }else{
              tag.className = "tag reservado";
              tag.textContent = "reservado";
              if(btnConfirm) btnConfirm.style.display = "";
            }
          }
        });

        const badge = card.querySelector(".agDayCount");
        if(badge) badge.textContent = String(dayCount);
        card.style.display = (dayCount > 0) ? "" : "none";
      });

      agTotal.textContent = String(totalShown);
      saveAgFilters();
      updateAgLastUpdate();
    }

    function handlePeriodoChange(){
      if (agPeriodo.value === "mes_inteiro"){
        agMesWrap.style.display = "";
        if (!agMesMonth.value) agMesMonth.value = "";
        if (!agMesYear.value) agMesYear.value = "";
        applyAgendamentos();
        return;
      }
      agMesWrap.style.display = "none";
      applyAgendamentos();
    }

    ["change","input"].forEach(evt=>{
      agBarberFilter.addEventListener(evt, applyAgendamentos);
      agTipo.addEventListener(evt, applyAgendamentos);
      agMesMonth.addEventListener(evt, applyAgendamentos);
      agMesYear.addEventListener(evt, applyAgendamentos);
    });
    agPeriodo.addEventListener("change", handlePeriodoChange);

    (function initAgendamentoFiltro(){
      buildMonthYearOptions();

      try{
        const raw = localStorage.getItem("ag_filters_v1");
        if(raw){
          const f = JSON.parse(raw);
          if(f && typeof f === "object"){
            if(typeof f.barber === "string") agBarberFilter.value = f.barber;
            if(typeof f.periodo === "string") agPeriodo.value = f.periodo;
            if(typeof f.tipo === "string") agTipo.value = f.tipo;
            if(typeof f.mm === "string") agMesMonth.value = f.mm;
            if(typeof f.yy === "string") agMesYear.value = f.yy;
          }
        }else{
          if (agPeriodo) agPeriodo.value = "hoje";
          if (agTipo) agTipo.value = "todos";
          if (agMesMonth) agMesMonth.value = "";
          if (agMesYear) agMesYear.value = "";
        }
      }catch(e){
        if (agPeriodo) agPeriodo.value = "hoje";
        if (agTipo) agTipo.value = "todos";
        if (agMesMonth) agMesMonth.value = "";
        if (agMesYear) agMesYear.value = "";
      }

      if (agPeriodo.value === "mes_inteiro") agMesWrap.style.display = "";
      else agMesWrap.style.display = "none";

      applyAgendamentos();
      updateAgLastUpdate();
    })();

    function updateAgLastUpdate(){
      const el = document.getElementById("agLastUpdate");
      if(!el) return;
      const d = new Date();
      el.textContent = `${pad2(d.getHours())}:${pad2(d.getMinutes())}:${pad2(d.getSeconds())}`;
    }

    function saveAgFilters(){
      try{
        const payload = {
          barber: agBarberFilter.value || "",
          periodo: agPeriodo.value || "hoje",
          tipo: agTipo.value || "todos",
          mm: agMesMonth.value || "",
          yy: agMesYear.value || ""
        };
        localStorage.setItem("ag_filters_v1", JSON.stringify(payload));
      }catch(e){}
    }

    const AG_AUTO_INTERVAL_SEC = <%= agRefreshSec %>;

let agAutoTimer = null;
let agAutoRemaining = AG_AUTO_INTERVAL_SEC;

function setAutoRefreshUI(isOn){
  const next = document.getElementById("agNextRefresh");
  if(next) next.textContent = isOn ? `${agAutoRemaining}s` : "—";
}

function stopAutoRefresh(){
  if(agAutoTimer){
    clearInterval(agAutoTimer);
    agAutoTimer = null;
  }
  agAutoRemaining = AG_AUTO_INTERVAL_SEC;
  setAutoRefreshUI(false);
}

function startAutoRefreshIfNeeded(){
  const agTab = document.getElementById("tabAgendamentos");
  const isAgActive = agTab && agTab.classList.contains("active");

  if(!isAgActive){
    stopAutoRefresh();
    return;
  }

  if(agAutoTimer) return;

  agAutoRemaining = AG_AUTO_INTERVAL_SEC;
  setAutoRefreshUI(true);

  agAutoTimer = setInterval(()=>{
    const agTabNow = document.getElementById("tabAgendamentos");
    const stillActive = agTabNow && agTabNow.classList.contains("active");

    if(!stillActive){
      stopAutoRefresh();
      return;
    }

    agAutoRemaining -= 1;
    const next = document.getElementById("agNextRefresh");
    if(next) next.textContent = `${agAutoRemaining}s`;

    if(agAutoRemaining <= 0){
      saveAgFilters();
      const url = new URL(window.location.href);
      url.searchParams.set("tab", "agendamentos");
      url.searchParams.set("_t", String(Date.now()));
      window.location.href = url.toString();
    }
  }, 1000);
}

    const agRefreshBtn = document.getElementById("agRefreshBtn");
    if(agRefreshBtn){
      agRefreshBtn.addEventListener("click", ()=>{
        saveAgFilters();
        const url = new URL(window.location.href);
        url.searchParams.set("tab", "agendamentos");
        url.searchParams.set("_t", String(Date.now()));
        window.location.href = url.toString();
      });
    }

    const admOverlay = document.getElementById("admOverlay");
    const admData = document.getElementById("admData");
    const admBarberId = document.getElementById("admBarberId");
    const admServiceId = document.getElementById("admServiceId");
    const admHorario = document.getElementById("admHorario");
    const admHorarioMsg = document.getElementById("admHorarioMsg");

    const admCalTitle = document.getElementById("admCalTitle");
    const admDays = document.getElementById("admDays");
    const admPrevMonth = document.getElementById("admPrevMonth");
    const admNextMonth = document.getElementById("admNextMonth");
    const admCancelCal = document.getElementById("admCancelCal");
    const admOkCal = document.getElementById("admOkCal");

    const swapOverlay = document.getElementById("swapOverlay");
    const swapPlanId = document.getElementById("swapPlanId");
    const swapBarberId = document.getElementById("swapBarberId");
    const swapOriginalDate = document.getElementById("swapOriginalDate");
    const swapOriginalHorario = document.getElementById("swapOriginalHorario");
    const swapDateDisplay = document.getElementById("swapDateDisplay");
    const swapDate = document.getElementById("swapDate");
    const swapHorario = document.getElementById("swapHorario");
    const swapHorarioMsg = document.getElementById("swapHorarioMsg");
    const swapNome = document.getElementById("swapNome");
    const swapBarbeiro = document.getElementById("swapBarbeiro");
    const swapAtual = document.getElementById("swapAtual");
    const swapCancelBtn = document.getElementById("swapCancelBtn");

    let calMonth = new Date();
    let selectedYMD = null;
    let calTarget = "manual";

    function openSharedCal(target){
      calTarget = target || "manual";

      let initialYMD = null;
      if(calTarget === "mensalista"){
        initialYMD = dmyToYMD(menStart?.value || "");
      }else if(calTarget === "trocaMensalista"){
        initialYMD = swapDate?.value || swapOriginalDate?.value || null;
      }else{
        initialYMD = dmyToYMD(admData?.value || "");
      }

      if(initialYMD){
        selectedYMD = initialYMD;
        const d = parseYMD(initialYMD);
        if(d) calMonth = new Date(d.getFullYear(), d.getMonth(), 1);
      }else{
        const now = new Date();
        calMonth = new Date(now.getFullYear(), now.getMonth(), 1);
        selectedYMD = fmtYMD(new Date(now.getFullYear(), now.getMonth(), now.getDate()));
      }

      if(calTarget === "trocaMensalista"){
        swapOverlay.classList.remove("show");
      }

      admOverlay.classList.add("show");
      renderCal();
    }

    function closeAdmCal(){
      admOverlay.classList.remove("show");
      if(calTarget === "trocaMensalista"){
        swapOverlay.classList.add("show");
      }
    }
    function closeSwapOverlay(){ swapOverlay.classList.remove("show"); }

    function renderCal(){
      const y = calMonth.getFullYear();
      const m = calMonth.getMonth();
      const monthNames = ["Janeiro","Fevereiro","Março","Abril","Maio","Junho","Julho","Agosto","Setembro","Outubro","Novembro","Dezembro"];
      admCalTitle.textContent = `${monthNames[m]} ${y}`;

      const first = new Date(y, m, 1);
      const startDow = first.getDay();
      const daysInMonth = new Date(y, m+1, 0).getDate();

      const today = new Date();
      const todayStart = new Date(today.getFullYear(), today.getMonth(), today.getDate());

      admDays.innerHTML = "";

      for(let i=0;i<startDow;i++){
        const div = document.createElement("div");
        div.className = "day muted";
        div.textContent = "";
        admDays.appendChild(div);
      }

      for(let d=1; d<=daysInMonth; d++){
        const dt = new Date(y, m, d);
        const ymd = fmtYMD(dt);
        const div = document.createElement("div");
        div.className = "day";
        div.textContent = String(d);

        const allowPastDates = calTarget === "mensalista";

        if(!allowPastDates && dt < todayStart){
          div.classList.add("disabled");
        }else{
          div.addEventListener("click", ()=>{
            selectedYMD = ymd;
            renderCal();
          });
        }

        if(selectedYMD === ymd) div.classList.add("selected");
        admDays.appendChild(div);
      }
    }

    admPrevMonth.addEventListener("click", ()=>{ calMonth = new Date(calMonth.getFullYear(), calMonth.getMonth()-1, 1); renderCal(); });
    admNextMonth.addEventListener("click", ()=>{ calMonth = new Date(calMonth.getFullYear(), calMonth.getMonth()+1, 1); renderCal(); });
    admCancelCal.addEventListener("click", closeAdmCal);
    admOkCal.addEventListener("click", ()=>{
      if(!selectedYMD) { alert("Selecione uma data."); return; }
      const d = parseYMD(selectedYMD);

      if(calTarget === "mensalista"){
        menStart.value = fmtDMYSlash(d);
        closeAdmCal();
        updateMensalistaDateFields();
        refreshMensalistaHorarios();
        return;
      }

      if(calTarget === "trocaMensalista"){
        swapDate.value = selectedYMD;
        swapDateDisplay.value = fmtDMYSlash(d);
        closeAdmCal();
        refreshTrocaMensalistaHorarios();
        return;
      }

      admData.value = fmtDMYSlash(d);
      closeAdmCal();
      refreshAdminHorarios();
    });

    admData.addEventListener("click", ()=>openSharedCal("manual"));

    async function refreshAdminHorarios(){
      admHorario.innerHTML = `<option value="">Selecione barbeiro, serviço e data</option>`;
      admHorario.disabled = true;
      admHorarioMsg.textContent = "";

      const b = admBarberId.value;
      const s = admServiceId.value;
      const dmy = admData.value;
      if(!b || !s || !dmy) return;

      const ymd = dmyToYMD(dmy);
      if(!ymd) return;

      try{
        const r = await fetch(`/horarios?barberId=${encodeURIComponent(b)}&serviceId=${encodeURIComponent(s)}&data=${encodeURIComponent(ymd)}`);
        const slots = await r.json();

        let finalSlots = Array.isArray(slots) ? slots.slice() : [];

        const today = new Date();
        const todayYMD = fmtYMD(new Date(today.getFullYear(), today.getMonth(), today.getDate()));
        if(ymd === todayYMD){
          const nowMin = minutesNow();
          finalSlots = finalSlots.filter(h=>{
            const slotMin = timeToMinutes(h);
            return slotMin != null && (slotMin - nowMin) >= 10;
          });
        }

        if(!finalSlots.length){
          admHorario.innerHTML = `<option value="">Sem horários disponíveis</option>`;
          admHorario.disabled = true;
          admHorarioMsg.textContent = "Sem horários disponíveis.";
          return;
        }

        admHorario.innerHTML = `<option value="">Selecione</option>` + finalSlots.map(h=>`<option value="${h}">${h}</option>`).join("");
        admHorario.disabled = false;
      }catch(e){
        admHorarioMsg.textContent = "Erro ao carregar horários.";
      }
    }
    admBarberId.addEventListener("change", refreshAdminHorarios);
    if (admServiceId) admServiceId.addEventListener("change", refreshAdminHorarios);

    async function refreshTrocaMensalistaHorarios(){
      swapHorario.innerHTML = `<option value="">Selecione a nova data</option>`;
      swapHorario.disabled = true;
      if(swapHorarioMsg) swapHorarioMsg.textContent = "";

      const barberId = swapBarberId?.value;
      const ymd = swapDate?.value;
      if(!barberId || !ymd) return;

      if(swapHorarioMsg) swapHorarioMsg.textContent = "Carregando horários...";
      try{
        const r = await fetch(`/horarios?barberId=${encodeURIComponent(barberId)}&data=${encodeURIComponent(ymd)}`);
        const slots = await r.json();

        if(!Array.isArray(slots) || !slots.length){
          swapHorario.innerHTML = `<option value="">Sem horários disponíveis</option>`;
          swapHorario.disabled = true;
          if(swapHorarioMsg) swapHorarioMsg.textContent = "Sem horários disponíveis.";
          return;
        }

        swapHorario.innerHTML = `<option value="">Selecione</option>` + slots.map(h=>`<option value="${h}">${h}</option>`).join("");
        swapHorario.disabled = false;
        if(swapHorarioMsg) swapHorarioMsg.textContent = "";
      }catch(e){
        if(swapHorarioMsg) swapHorarioMsg.textContent = "Erro ao carregar horários.";
      }
    }

    window.abrirTrocaMensalista = function(btn){
      const slot = btn?.closest(".agSlot");
      if(!slot) return;

      swapPlanId.value = slot.dataset.planId || "";
      swapBarberId.value = slot.dataset.barberId || "";
      swapOriginalDate.value = slot.dataset.date || "";
      swapOriginalHorario.value = slot.dataset.horario || "";
      swapDate.value = slot.dataset.date || "";
      swapDateDisplay.value = ymdToSlash(slot.dataset.date || "");
      swapHorario.innerHTML = `<option value="">Selecione a nova data</option>`;
      swapHorario.disabled = true;
      if(swapHorarioMsg) swapHorarioMsg.textContent = "";
      swapNome.textContent = slot.dataset.nome || "—";
      swapBarbeiro.textContent = slot.dataset.barberName || "—";
      swapAtual.textContent = `${ymdToSlash(slot.dataset.date || "")} às ${slot.dataset.horario || ""}`;

      swapOverlay.classList.add("show");
      refreshTrocaMensalistaHorarios();
    };

    if(swapDateDisplay){
      swapDateDisplay.addEventListener("click", ()=>openSharedCal("trocaMensalista"));
    }
    if(swapCancelBtn){
      swapCancelBtn.addEventListener("click", closeSwapOverlay);
    }

    const menForm = document.getElementById("mensalistaForm");
    const menPlanId = document.getElementById("menPlanId");
    const menBarberId = document.getElementById("menBarberId");
    const menNome = document.getElementById("menNome");
    const menWeekdayHidden = document.getElementById("menWeekdayHidden");
    const menHorario = document.getElementById("menHorario");
    const menHorarioMsg = document.getElementById("menHorarioMsg");
    const menStart = document.getElementById("menStart");
    const menEnd = document.getElementById("menEnd");
    const menSubmitBtn = document.getElementById("menSubmitBtn");
    const menCancelEdit = document.getElementById("menCancelEdit");

    const menEditPill = document.getElementById("menEditPill");
    const menEditName = document.getElementById("menEditName");

    function updateMensalistaDateFields(){
      const startYMD = dmyToYMD(menStart?.value || "");
      const endYMD = startYMD ? calcMensalistaEnd(startYMD) : "";
      if(menEnd) menEnd.value = endYMD ? fmtDMYSlash(parseYMD(endYMD)) : "";
      if(menWeekdayHidden) menWeekdayHidden.value = startYMD ? weekdayFromYMD(startYMD) : "";
    }

    async function refreshMensalistaHorarios(){
      menHorario.innerHTML = `<option value="">Selecione barbeiro e data inicial</option>`;
      menHorario.disabled = true;
      if(menHorarioMsg) menHorarioMsg.textContent = "";

      const b = menBarberId?.value;
      const startYMD = dmyToYMD(menStart?.value || "");
      if(!b || !startYMD) return;

      updateMensalistaDateFields();

      if(menHorarioMsg) menHorarioMsg.textContent = "Carregando horários...";
      try{
        const r = await fetch(`/horarios?barberId=${encodeURIComponent(b)}&data=${encodeURIComponent(startYMD)}`);
        const slots = await r.json();

        if(!Array.isArray(slots) || slots.length === 0){
          menHorario.innerHTML = `<option value="">Sem horários disponíveis</option>`;
          menHorario.disabled = true;
          if(menHorarioMsg) menHorarioMsg.textContent = "Sem horários.";
          return;
        }

        menHorario.innerHTML = `<option value="">Selecione</option>` + slots.map(h => `<option value="${h}">${h}</option>`).join("");
        menHorario.disabled = false;
        if(menHorarioMsg) menHorarioMsg.textContent = "";
      }catch(e){
        if(menHorarioMsg) menHorarioMsg.textContent = "Erro ao carregar horários.";
      }
    }

    function setMensalistaEditMode(on, nomeLabel){
      if(on){
        menCancelEdit.style.display = "";
        menSubmitBtn.textContent = "Salvar edição";
        menEditPill.style.display = "";
        menEditName.textContent = nomeLabel || "";
      }else{
        menCancelEdit.style.display = "none";
        menSubmitBtn.textContent = "Salvar plano mensalista";
        menEditPill.style.display = "none";
        menEditName.textContent = "";
      }
    }

    function resetMensalistaForm(){
      if(menPlanId) menPlanId.value = "";
      menForm.action = "/admin/mensalistas";
      menBarberId.value = "";
      menNome.value = "";
      menStart.value = fmtDMYSlash(new Date());
      updateMensalistaDateFields();
      menHorario.innerHTML = `<option value="">Selecione barbeiro e data inicial</option>`;
      menHorario.disabled = true;
      if(menHorarioMsg) menHorarioMsg.textContent = "";
      setMensalistaEditMode(false);
    }

    window.startEditMensalista = async function(btn){
      const tr = btn?.closest("tr");
      if(!tr) return;

      const id = tr.dataset.menId;
      const barberId = tr.dataset.menBarberId;
      const nome = tr.dataset.menNome || "";
      const start = tr.dataset.menStart || "";
      const horario = tr.dataset.menHorario || "";

      menPlanId.value = id || "";
      menBarberId.value = barberId || "";
      menNome.value = nome;
      menStart.value = start ? fmtDMYSlash(parseYMD(start)) : fmtDMYSlash(new Date());
      updateMensalistaDateFields();

      setMensalistaEditMode(true, nome);

      await refreshMensalistaHorarios();
      menHorario.value = horario;

      menForm.action = `/admin/mensalistas/${encodeURIComponent(id)}/update`;
      menForm.scrollIntoView({ behavior:"smooth", block:"start" });
    };

    menCancelEdit.addEventListener("click", resetMensalistaForm);
    menBarberId.addEventListener("change", refreshMensalistaHorarios);
    menStart.addEventListener("click", ()=>openSharedCal("mensalista"));

    const menBarberFilter = document.getElementById("menBarberFilter");
    const menTotal = document.getElementById("menTotal");

    function applyMenBarberFilter(){
      const v = menBarberFilter ? menBarberFilter.value : "";
      let shown = 0;

      document.querySelectorAll(".menRow").forEach(tr=>{
        const bid = tr.dataset.menBarberId || "";
        const ok = (!v) || (bid === v);
        tr.style.display = ok ? "" : "none";
        if(ok) shown++;
      });

      if(menTotal) menTotal.textContent = String(shown);
    }

    if(menBarberFilter){
      menBarberFilter.addEventListener("change", applyMenBarberFilter);
      setTimeout(applyMenBarberFilter, 0);
    }

    const configBarberSelect = document.getElementById("configBarberSelect");
    if(configBarberSelect){
      configBarberSelect.addEventListener("change", ()=>{
        const barberId = configBarberSelect.value || "";
        const url = new URL(window.location.href);
        url.searchParams.set("tab", "config");

        if(barberId) url.searchParams.set("configBarberId", barberId);
        else url.searchParams.delete("configBarberId");

        window.location.href = url.toString();
      });
    }

    document.addEventListener("DOMContentLoaded", ()=>{
  setAutoRefreshUI(false);

  if(menStart && !menStart.value) menStart.value = fmtDMYSlash(new Date());
  updateMensalistaDateFields();

  const tab = new URLSearchParams(window.location.search).get("tab");
  if(tab === "configgeral") activateTab("tabBtnBarbeiros");
  if(tab === "config") activateTab("tabBtnConfig");
  if(tab === "mensalistas") activateTab("tabBtnMensalistas");
  if(tab === "manual") activateTab("tabBtnManual");
  if(tab === "agendamentos") activateTab("tabBtnAgendamentos");

  startAutoRefreshIfNeeded();
});

    function urlBase64ToUint8Array(base64String) {
      const padding = "=".repeat((4 - (base64String.length % 4)) % 4);
      const base64 = (base64String + padding).replace(/-/g, "+").replace(/_/g, "/");
      const rawData = window.atob(base64);
      const outputArray = new Uint8Array(rawData.length);

      for (let i = 0; i < rawData.length; ++i) {
        outputArray[i] = rawData.charCodeAt(i);
      }
      return outputArray;
    }

    async function fetchPushPublicKey() {
      const res = await fetch("/admin/push/public-key", {
        method: "GET",
        headers: { "Accept": "application/json" }
      });

      if (!res.ok) {
        throw new Error("Não foi possível obter a chave pública do push.");
      }

      return res.json();
    }

    async function sendSubscriptionToServer(subscription) {
      const res = await fetch("/admin/push/subscribe", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(subscription)
      });

      if (!res.ok) {
        throw new Error("Não foi possível salvar a inscrição do dispositivo.");
      }

      return res.json();
    }

    async function removeSubscriptionFromServer(endpoint) {
      const res = await fetch("/admin/push/unsubscribe", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ endpoint })
      });

      if (!res.ok) {
        throw new Error("Não foi possível remover a inscrição do dispositivo.");
      }

      return res.json();
    }

    async function getServiceWorkerRegistrationReady() {
      const reg = await navigator.serviceWorker.register("/sw.js");
      await navigator.serviceWorker.ready;
      return reg;
    }

    function setPushStatus(text, type) {
      const el = document.getElementById("pushStatus");
      if (!el) return;
      el.textContent = text;
      el.className = `notifStatus ${type || ""}`.trim();
    }

    function updatePushButtons(hasSubscription) {
      const btnAtivar = document.getElementById("btnAtivarPush");
      const btnDesativar = document.getElementById("btnDesativarPush");

      if (!btnAtivar || !btnDesativar) return;

      if (hasSubscription) {
        btnAtivar.style.display = "none";
        btnDesativar.style.display = "";
      } else {
        btnAtivar.style.display = "";
        btnDesativar.style.display = "none";
      }
    }

    async function syncPushUIState() {
      const btnAtivar = document.getElementById("btnAtivarPush");
      const btnDesativar = document.getElementById("btnDesativarPush");

      if (!btnAtivar || !btnDesativar) return;

      if (!("serviceWorker" in navigator) || !("PushManager" in window) || !("Notification" in window)) {
        setPushStatus("Este navegador/dispositivo não suporta notificações push.", "err");
        btnAtivar.disabled = true;
        btnDesativar.disabled = true;
        return;
      }

      try {
        const reg = await getServiceWorkerRegistrationReady();
        const sub = await reg.pushManager.getSubscription();

        if (Notification.permission === "denied") {
          setPushStatus("As notificações estão bloqueadas no navegador deste aparelho.", "err");
          updatePushButtons(!!sub);
          return;
        }

        if (sub) {
          setPushStatus("Notificações ativas neste aparelho.", "ok");
          updatePushButtons(true);
        } else {
          if (Notification.permission === "granted") {
            setPushStatus("Permissão concedida, mas este aparelho ainda não foi inscrito.", "warn");
          } else {
            setPushStatus("Notificações ainda não ativadas neste aparelho.", "warn");
          }
          updatePushButtons(false);
        }
      } catch (err) {
        console.error("❌ syncPushUIState:", err);
        setPushStatus("Erro ao verificar o status das notificações.", "err");
      }
    }

    async function ativarPushNoAparelho() {
      try {
        if (!("serviceWorker" in navigator) || !("PushManager" in window) || !("Notification" in window)) {
          setPushStatus("Este navegador/dispositivo não suporta notificações push.", "err");
          return;
        }

        const permission = await Notification.requestPermission();
        if (permission !== "granted") {
          setPushStatus("Permissão de notificações não concedida.", "err");
          return;
        }

        const reg = await getServiceWorkerRegistrationReady();
        let sub = await reg.pushManager.getSubscription();

        if (!sub) {
          const data = await fetchPushPublicKey();
          const publicKey = data?.publicKey;

          if (!publicKey) {
            throw new Error("Chave pública VAPID não encontrada.");
          }

          sub = await reg.pushManager.subscribe({
            userVisibleOnly: true,
            applicationServerKey: urlBase64ToUint8Array(publicKey)
          });
        }

        await sendSubscriptionToServer(sub);

        setPushStatus("Notificações ativadas com sucesso neste aparelho.", "ok");
        updatePushButtons(true);
      } catch (err) {
        console.error("❌ ativarPushNoAparelho:", err);
        setPushStatus("Erro ao ativar as notificações neste aparelho.", "err");
      }
    }

    async function desativarPushNoAparelho() {
      try {
        const reg = await getServiceWorkerRegistrationReady();
        const sub = await reg.pushManager.getSubscription();

        if (!sub) {
          setPushStatus("Este aparelho já estava sem inscrição ativa.", "warn");
          updatePushButtons(false);
          return;
        }

        const endpoint = sub.endpoint;
        await sub.unsubscribe();

        if (endpoint) {
          await removeSubscriptionFromServer(endpoint);
        }

        setPushStatus("Notificações desativadas neste aparelho.", "warn");
        updatePushButtons(false);
      } catch (err) {
        console.error("❌ desativarPushNoAparelho:", err);
        setPushStatus("Erro ao desativar as notificações neste aparelho.", "err");
      }
    }

    document.addEventListener("DOMContentLoaded", () => {
      const btnAtivarPush = document.getElementById("btnAtivarPush");
      const btnDesativarPush = document.getElementById("btnDesativarPush");

      if (btnAtivarPush) {
        btnAtivarPush.addEventListener("click", ativarPushNoAparelho);
      }

      if (btnDesativarPush) {
        btnDesativarPush.addEventListener("click", desativarPushNoAparelho);
      }

      syncPushUIState();
    });
  </script>
</body>
</html>
